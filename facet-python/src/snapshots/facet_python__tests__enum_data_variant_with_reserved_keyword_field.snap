class Move(TypedDict, total=False):
    Move: Required[MoveData]

type MoveData = TypedDict(
    "MoveData",
    {"from": Required[str], "to": Required[str], "amount": Required[float]},
    total=False,
)
type Transfer = Move | Literal["Cancel"]
