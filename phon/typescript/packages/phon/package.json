{
  "name": "@bearcove/phon",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        }
      }
    }
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "@bearcove/phon-engine": "workspace:*",
    "@bearcove/phon-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "license": "MIT OR Apache-2.0",
  "description": "The phon front door for TypeScript: the typed encode/decode API over codegen-emitted accessors.",
  "repository": "https://github.com/bearcove/phon",
  "homepage": "https://github.com/bearcove/phon",
  "keywords": ["phon", "serialization", "rpc", "typescript"]
}
