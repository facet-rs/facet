{
  "name": "vix-lang",
  "displayName": "Vix",
  "description": "Vix language support backed by vix-lsp",
  "version": "0.1.0",
  "publisher": "facet-rs",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:vix"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vix",
        "aliases": ["Vix", "vix"],
        "extensions": [".vix"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Vix",
      "properties": {
        "vix.server.path": {
          "type": "string",
          "default": "vix-lsp",
          "description": "Path to the vix-lsp executable"
        },
        "vix.server.logDir": {
          "type": "string",
          "default": "/tmp/vix-lsp",
          "description": "Directory for vix-lsp daily rolling trace logs"
        },
        "vix.server.logLevel": {
          "type": "string",
          "default": "info",
          "description": "Tracing filter for vix-lsp stderr and file logs"
        },
        "vix.server.logRetention": {
          "type": "number",
          "default": 7,
          "description": "Maximum number of vix-lsp daily log files to retain"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
