// Rung 029 — fold over an array runs in field order.
#[test]
fn array_fold() -> Stream<Check> {
    let xs = [1, 2, 3, 4];
    yield expect_eq(xs.fold(0, |acc, n| acc + n), 10);
    yield expect_eq(xs.fold("", |acc, n| acc + "|"), "||||");
    let order_sensitive = ["a", "b", "c"].fold("", |acc, s| acc + s);
    yield expect_eq(order_sensitive, "abc");
}
