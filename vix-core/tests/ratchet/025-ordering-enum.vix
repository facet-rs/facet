// Rung 025 — Ordering is an ordinary enum: match on comparison results.
fn describe(a: Int) where { b: Int } -> String {
    match a <=> b {
        Ordering::Less => "ascending",
        Ordering::Equal => "same",
        Ordering::Greater => "descending",
    }
}

#[test]
fn ordering_enum() -> Stream<Check> {
    let ascending = describe(1) where { b: 2 };
    let same = describe(5) where { b: 5 };
    yield expect_eq(ascending, "ascending");
    yield expect_eq(same, "same");
}
