
// Rung 139 — identity at depth: build a 100k-deep nested structure and
// intern it. The walk reads each child's STORED hash — O(depth) total,
// once per node ever — not O(depth²) rehashing of subtrees.
enum Chain { End, Link(Int, Chain) }

#[test { budget_wall: 5s, budget_rss: 512MB }]
fn deep_nesting_identity() -> Stream<Check> {
    let chain = (range where { from: 0, to: 100000 }).fold(Chain::End, |acc, i| Chain::Link(i, acc));
    let twin = (range where { from: 0, to: 100000 }).fold(Chain::End, |acc, i| Chain::Link(i, acc));
    yield expect_eq(chain, twin);
}
