// Rung 056 — described-but-undemanded costs nothing. (demand.md)
fn cheap() -> Int { 1 }
fn landmine() -> Int { 1 / 0 }

#[test]
fn undemanded_is_free() -> Stream<Check> {
    let useful = cheap();
    let unused = landmine();
    yield expect_eq(useful, 1);
    yield never_demanded(landmine());
}
