//! uses: lib/geometry.vix
//! rerun

// Rung 110 — cross-module calls memoize like any other demand: warm
// across runs through an import boundary.
import geometry::{Point, magnitude_sq};

#[test]
fn module_memo_boundary() -> Stream<Check> {
    yield expect_eq(magnitude_sq(Point { x: 6, y: 8 }), 100);
    yield never_demanded(magnitude_sq(Point { x: 6, y: 8 }));
}
