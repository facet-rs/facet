
// Rung 050 — a 10-million-iteration tail loop under a wall budget.
// The budget is generous for a fused interior (native ops, no machinery
// per iteration) and unreachable for an evaluator that touches the
// scheduler, memo, or identity machinery once per iteration: at 10µs of
// bookkeeping per step, this rung takes 100 seconds. The gap is
// architectural, not constant-factor.
fn count_up(n: Int) where { limit: Int, acc: Int } -> Int {
    if n == limit { acc } else { count_up(n + 1) where { limit, acc: acc + n } }
}

#[test { budget_wall: 5s, budget_rss: 256MB }]
fn deep_tail_recursion() -> Stream<Check> {
    let sum = count_up(0) where { limit: 10000000, acc: 0 };
    yield expect_eq(sum, 49999995000000);
    yield scheduler_requests_at_most(10);
    yield memo_entries_at_most(10);
}
