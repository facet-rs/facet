        Self {
            caller: self
                .caller
                .with_middleware(calc_service_descriptor(), middleware),
            connection: self.connection,
        }
    }
    pub async fn div(&self, a: f64, b: f64) -> Result<f64, ::vox::VoxError<DivError>> {
        let method_id = calc_service_descriptor().methods[0usize].id;
        let args = (a, b);
        let mut metadata = Default::default();
        let req = ::vox::RequestCall {
            method_id,
            channels: Default::default(),
            args: ::vox::Payload::outgoing(&args),
            metadata,
            schemas: Default::default(),
        };
        let with_tracker = match self.caller.call(req).await {
            Ok(with_tracker) => with_tracker,
            Err(e) => {
                return Err(match e {
                    ::vox::VoxError::UnknownMethod => ::vox::VoxError::<DivError>::UnknownMethod,
                    ::vox::VoxError::InvalidPayload(msg) => {
                        ::vox::VoxError::<DivError>::InvalidPayload(msg)
                    }
                    ::vox::VoxError::Cancelled => ::vox::VoxError::<DivError>::Cancelled,
                    ::vox::VoxError::ConnectionClosed => {
                        ::vox::VoxError::<DivError>::ConnectionClosed
                    }
                    ::vox::VoxError::ConnectionShutdown => {
                        ::vox::VoxError::<DivError>::ConnectionShutdown
                    }
                    ::vox::VoxError::SendFailed => ::vox::VoxError::<DivError>::SendFailed,
                    ::vox::VoxError::TimedOut => ::vox::VoxError::<DivError>::TimedOut,
                    ::vox::VoxError::Indeterminate => ::vox::VoxError::<DivError>::Indeterminate,
                    ::vox::VoxError::User(never) => match *never {},
                });
            }
        };
        let ::vox::WithTracker {
            value: response,
            tracker: schema_tracker,
            fds: __vox_frame_fds,
        } = with_tracker;
        ::vox::provide_fds(__vox_frame_fds, move || {
            let response = response.get();
            let ret_bytes = match &response.ret {
                ::vox::Payload::Encoded(bytes) => bytes,
                _ => {
                    return Err(::vox::VoxError::<DivError>::InvalidPayload(
                        "response not Encoded".into(),
                    ));
                }
            };
            let result: Result<f64, ::vox::VoxError<DivError>> =
                ::vox::schema_deser::schema_deserialize_response::<
                    Result<f64, ::vox::VoxError<DivError>>,
                >(ret_bytes, method_id, &schema_tracker)
                .map_err(|e| ::vox::VoxError::<DivError>::InvalidPayload(e.to_string()))?;
            match result {
                Ok(ret) => Ok(ret),
                Err(err) => Err(err),
            }
        })
    }
}
