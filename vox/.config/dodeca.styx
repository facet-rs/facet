@schema {id crate:dodeca-config@1, cli ddc}

source {
    content docs/content
    repo "https://github.com/facet-rs/facet/tree/main/vox"
    impls (
        {
            name rust
            root .
            include ("rust/**/src/**/*.rs")
            exclude ("target/**")
            test_include ("rust/**/tests/**/*.rs")
        }
    )
}
