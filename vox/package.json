{
  "name": "@bearcove/vox-typescript",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter './typescript/packages/*' run build",
    "check": "pnpm -r run check && pnpm run check:ts-boundaries",
    "check:ts-boundaries": "node scripts/check-ts-package-boundaries.mjs",
    "test": "pnpm -r run test",
    "lint": "oxlint typescript"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.8.0"
  },
  "version": "0.0.0"
}
