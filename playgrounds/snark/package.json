{
  "name": "@bearcove/snark-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @bearcove/snark-wasm run build && vite",
    "build": "pnpm --filter @bearcove/snark-wasm run build && tsc --noEmit && vite build",
    "test": "node --experimental-strip-types --test tests/bundlePaths.test.ts tests/highlight.test.ts tests/treeSitterDslRuntime.test.ts",
    "test:all": "pnpm run test && pnpm run test:flow",
    "test:flow": "pnpm --filter @bearcove/snark-wasm run build && node --experimental-strip-types --test tests/wasmFlow.test.ts",
    "test:paths": "node --experimental-strip-types --test tests/bundlePaths.test.ts"
  },
  "dependencies": {
    "@bearcove/snark-wasm": "workspace:*",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "8.1.0"
  }
}
