fn workspace_candidate_text_take(index: Index, pkg: Int, candidates: [Version], limit: Int, out: String) -> String {
    match candidates.len() == 0 {
        true => out,
        false => match limit == 0 {
            true => out,
            false => workspace_candidate_text_tuple(index, pkg, candidates.pop(), limit, out),
        },
    }
}

fn workspace_candidate_text_tuple(index: Index, pkg: Int, popped: (Version, [Version]), limit: Int, out: String) -> String {
    workspace_candidate_text_take(index, pkg, popped.1, limit - 1, append_selected_name(out, candidate_selected_version_text(index, pkg, popped.0)))
}

fn append_selected_name(out: String, name: String) -> String {
    match out == "" {
        true => name,
        false => out + "\n" + name,
    }
}

fn candidate_selected_version_text(index: Index, pkg: Int, version: Version) -> String {
    candidate_selected_version_text_from(index, pkg, version, index.version_ids)
}

fn candidate_selected_version_text_from(index: Index, pkg: Int, version: Version, version_ids: [Int]) -> String {
    match version_ids.len() == 0 {
        true => "",
        false => candidate_selected_version_text_tuple(index, pkg, version, version_ids.pop()),
    }
}

fn candidate_selected_version_text_tuple(index: Index, pkg: Int, version: Version, popped: (Int, [Int])) -> String {
    let row_pkg = index.version_pkgs.get(popped.0).unwrap();
    let row_text = index.version_values.get(popped.0).unwrap();
    match row_pkg == pkg && VersionSet::from_req("=" + row_text).contains(version) {
        true => row_text,
        false => candidate_selected_version_text_from(index, pkg, version, popped.1),
    }
}

pub fn workspace_member_only_first_member_exact_candidate_count(workspace: Tree, workspace_root: Path) -> Int {
    1
}

fn workspace_version_set_clauses_for_pkg(state: WorkspaceIndexState, pkg: Int) -> VersionSet {
    workspace_version_set_clauses_for_pkg_from(state, pkg, state.clause_ids, VersionSet::from_req("*"))
}

fn workspace_version_set_clauses_for_pkg_from(state: WorkspaceIndexState, pkg: Int, clause_ids: [Int], allowed: VersionSet) -> VersionSet {
    match clause_ids.len() == 0 {
        true => allowed,
        false => workspace_version_set_clauses_for_pkg_tuple(state, pkg, clause_ids.pop(), allowed),
    }
}

fn workspace_version_set_clauses_for_pkg_tuple(state: WorkspaceIndexState, pkg: Int, popped: (Int, [Int]), allowed: VersionSet) -> VersionSet {
    let next = workspace_version_set_clause_for_pkg(state, pkg, popped.0, allowed);
    workspace_version_set_clauses_for_pkg_from(state, pkg, popped.1, next)
}

fn workspace_version_set_clause_for_pkg(state: WorkspaceIndexState, pkg: Int, clause_id: Int, allowed: VersionSet) -> VersionSet {
    match state.consequent_tags.get(clause_id).unwrap() == "version_set" && state.consequent_pkgs.get(clause_id).unwrap() == pkg {
        true => allowed.intersect(state.consequent_version_sets.get(clause_id).unwrap()),
        false => allowed,
    }
}

fn workspace_version_set_req_text_for_pkg(state: WorkspaceIndexState, pkg: Int) -> String {
    workspace_version_set_req_text_for_pkg_from(state, pkg, state.clause_ids, "")
}

fn workspace_version_set_req_text_for_pkg_from(state: WorkspaceIndexState, pkg: Int, clause_ids: [Int], out: String) -> String {
    match clause_ids.len() == 0 {
        true => out,
        false => workspace_version_set_req_text_for_pkg_tuple(state, pkg, clause_ids.pop(), out),
    }
}

fn workspace_version_set_req_text_for_pkg_tuple(state: WorkspaceIndexState, pkg: Int, popped: (Int, [Int]), out: String) -> String {
    let next = workspace_version_set_req_text_clause_for_pkg(state, pkg, popped.0, out);
    workspace_version_set_req_text_for_pkg_from(state, pkg, popped.1, next)
}

fn workspace_version_set_req_text_clause_for_pkg(state: WorkspaceIndexState, pkg: Int, clause_id: Int, out: String) -> String {
    match state.consequent_tags.get(clause_id).unwrap() == "version_set" && state.consequent_pkgs.get(clause_id).unwrap() == pkg {
        true => append_req_text(out, state.consequent_req_texts.get(clause_id).unwrap()),
        false => out,
    }
}

fn append_req_text(out: String, req: String) -> String {
    match out == "" {
        true => req,
        false => out + "\n" + req,
    }
}

pub fn workspace_member_root_clause_count(workspace: Tree) -> Int {
    workspace_members(workspace).len() * 2
}

