    solve_selected_versions_text_from_workspace_state(state, workspace_problem(), target)
}

pub fn workspace_member_direct_sparse_solution_units_text_limit(workspace: Tree, workspace_root: Path, sparse_jsonl: String, target: String, limit: Int) -> String {
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let members = take_strings(workspace_members(workspace), limit, []);
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    let state = register_sparse_rows(rows, state);
    let state = register_workspace_direct_deps(workspace, workspace_root, members, state);
    solution_units_text_from_workspace_state_with_sparse_rows(workspace, workspace_root, rows, state, workspace_problem(), target)
}

pub fn workspace_member_direct_sparse_enabled_features_text_limit(workspace: Tree, workspace_root: Path, sparse_jsonl: String, target: String, limit: Int, package: String) -> String {
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let members = take_strings(workspace_members(workspace), limit, []);
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    let state = register_sparse_rows(rows, state);
    let state = register_workspace_direct_deps(workspace, workspace_root, members, state);
    let index = workspace_index_from_state(state);
    let result = solve(index, workspace_problem(), target);
    let state = register_selected_sparse_features(rows, state, result);
    match state.package_ids.get(package) {
        Some(pkg) => solution_unit_seed_features(state, result.enabled_feature_ids, pkg, []).join("\n"),
        None => "",
    }
}

pub fn workspace_member_direct_sparse_feature_target_debug_limit(workspace: Tree, workspace_root: Path, sparse_jsonl: String, target: String, limit: Int, package: String, feature: String) -> String {
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let state = workspace_index_state_with_sparse_rows_limit(workspace, workspace_root, sparse_jsonl, limit);
    let index = workspace_index_from_state(state);
    let result = solve(index, workspace_problem(), target);
    match state.package_ids.get(package) {
        Some(pkg) => match result.selected.get(pkg) {
            Some(version) => match selected_sparse_row(rows, state.names.get(pkg).unwrap(), workspace_selected_version_text(state, pkg, version)) {
                Some(row) => match sparse_feature_target(row, feature) {
                    Some(expr) => target + "\n" + expr + "\n" + bool_text(target_matches(expr, target)),
                    None => target + "\n<none>\ntrue",
                },
                None => target + "\n<missing-row>\nfalse",
            },
            None => target + "\n<not-selected>\nfalse",
        },
        None => target + "\n<missing-package>\nfalse",
    }
}

fn bool_text(value: Bool) -> String {
    match value {
        true => "true",
        false => "false",
    }
}

fn target_matches(expr: String, target: String) -> Bool {
    match expr == "" {
        true => true,
        false => match expr == "cfg(all())" {
            true => true,
            false => match expr == "cfg(windows)" {
                true => target.contains("windows"),
                false => match expr == "cfg(unix)" {
                    true => target_matches_unix(target),
                    false => match expr == "cfg(target_os = \"macos\")" {
                        true => target.contains("apple-darwin"),
                        false => match expr == "cfg(target_os = \"linux\")" {
                            true => target.contains("linux"),
                            false => match expr == "cfg(target_arch = \"x86_64\")" {
                                true => target.contains("x86_64"),
                                false => match expr == "cfg(target_arch = \"aarch64\")" {
                                    true => target.contains("aarch64"),
                                    false => false,
                                },
                            },
                        },
                    },
                },
            },
        },
    }
}

fn target_matches_unix(target: String) -> Bool {
    match target.contains("linux") {
        true => true,
        false => target.contains("apple-darwin"),
    }
}

fn solve_selected_versions_text_from_workspace_state(state: WorkspaceIndexState, problem: Problem, target: String) -> String {
    solve_selected_versions_text(workspace_index_from_state(state), problem, target)
}

fn workspace_index_dump(state: WorkspaceIndexState) -> String {
    let out = workspace_index_dump_packages(state, state.packages, "");
    let out = workspace_index_dump_versions(state, state.version_ids, out);
    workspace_index_dump_clauses(state, state.clause_ids, out)
}

fn workspace_index_dump_packages(state: WorkspaceIndexState, packages: [Int], out: String) -> String {
    match packages.len() == 0 {
        true => out,
        false => workspace_index_dump_packages_tuple(state, packages.pop(), out),
    }
}

pub fn workspace_index_package_names_text(state: WorkspaceIndexState) -> String {
    workspace_index_dump_packages(state, state.packages, "")
}

fn workspace_index_dump_packages_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), out: String) -> String {
    workspace_index_dump_packages(state, popped.1, append_index_dump_line(out, "p\t" + state.names.get(popped.0).unwrap()))
}

fn workspace_index_dump_versions(state: WorkspaceIndexState, version_ids: [Int], out: String) -> String {
    match version_ids.len() == 0 {
        true => out,
        false => workspace_index_dump_versions_tuple(state, version_ids.pop(), out),
    }
}

fn workspace_index_dump_versions_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), out: String) -> String {
    let pkg = state.version_pkgs.get(popped.0).unwrap();
    let line = "v\t" + state.names.get(pkg).unwrap() + "\t" + state.version_values.get(popped.0).unwrap();
    workspace_index_dump_versions(state, popped.1, append_index_dump_line(out, line))
}

fn workspace_index_dump_clauses(state: WorkspaceIndexState, clause_ids: [Int], out: String) -> String {
    match clause_ids.len() == 0 {
        true => out,
        false => workspace_index_dump_clauses_tuple(state, clause_ids.pop(), out),
    }
}

fn workspace_index_dump_clauses_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), out: String) -> String {
    workspace_index_dump_clauses(state, popped.1, append_index_dump_line(out, workspace_index_dump_clause(state, popped.0)))
}

fn workspace_index_dump_clause(state: WorkspaceIndexState, clause_id: Int) -> String {
    let guard_id = guard_id_for_clause(state, clause_id, state.guard_ids);
    let parent_pkg = state.guard_pkgs.get(guard_id).unwrap();
    let dep_pkg = state.consequent_pkgs.get(clause_id).unwrap();
    "c\t"
        + state.names.get(parent_pkg).unwrap()
        + "\t"
        + state.guard_version_values.get(guard_id).unwrap()
        + "\t"
        + state.consequent_tags.get(clause_id).unwrap()
        + "\t"
        + state.names.get(dep_pkg).unwrap()
        + "\t"
        + state.consequent_req_texts.get(clause_id).unwrap()
        + "\t"
        + state.gate_kinds.get(clause_id).unwrap()
}

fn guard_id_for_clause(state: WorkspaceIndexState, clause_id: Int, guard_ids: [Int]) -> Int {
    match guard_ids.pop() {
        popped => match state.guard_clause_ids.get(popped.0).unwrap() == clause_id {
            true => popped.0,
            false => guard_id_for_clause(state, clause_id, popped.1),
        },
    }
}

fn append_index_dump_line(out: String, line: String) -> String {
    match out == "" {
        true => line,
        false => out + "\n" + line,
    }
}

fn solution_units_text_from_workspace_state(workspace: Tree, workspace_root: Path, state: WorkspaceIndexState, problem: Problem, target: String) -> String {
    let index = workspace_index_from_state(state);
    let result = solve(index, problem, target);
    solution_units_text_from_packages(workspace, workspace_root, state, index, result, target, state.packages, "")
}

fn solution_units_text_from_workspace_state_with_sparse_rows(workspace: Tree, workspace_root: Path, rows: [SparseIndexRow], state: WorkspaceIndexState, problem: Problem, target: String) -> String {
    let index = workspace_index_from_state(state);
    let result = solve(index, problem, target);
    let state = register_selected_sparse_features(rows, state, result);
    solution_units_text_from_packages_with_sparse_rows(workspace, workspace_root, rows, state, index, result, target, state.packages, "")
}

fn solution_units_text_from_packages_with_sparse_rows(workspace: Tree, workspace_root: Path, rows: [SparseIndexRow], state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, packages: [Int], out: String) -> String {
    match packages.len() == 0 {
        true => out,
        false => solution_units_text_from_packages_with_sparse_rows_tuple(workspace, workspace_root, rows, state, index, result, target, packages.pop(), out),
    }
}

fn solution_units_text_from_packages_with_sparse_rows_tuple(workspace: Tree, workspace_root: Path, rows: [SparseIndexRow], state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, popped: (Int, [Int]), out: String) -> String {
    let out = solution_units_text_for_package_with_sparse_rows(workspace, workspace_root, rows, state, index, result, target, popped.0, out);
    solution_units_text_from_packages_with_sparse_rows(workspace, workspace_root, rows, state, index, result, target, popped.1, out)
}

fn solution_units_text_for_package_with_sparse_rows(workspace: Tree, workspace_root: Path, rows: [SparseIndexRow], state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, pkg: Int, out: String) -> String {
    match result.selected.get(pkg) {
        Some(version) => match state.names.get(pkg).unwrap() == "__workspace__" {
            true => out,
            false => solution_units_text_for_selected_package_with_sparse_rows(workspace, workspace_root, rows, state, index, result, target, pkg, workspace_selected_version_text(state, pkg, version), out),
        },
        None => out,
    }
}

fn solution_units_text_for_selected_package_with_sparse_rows(workspace: Tree, workspace_root: Path, rows: [SparseIndexRow], state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, pkg: Int, version: String, out: String) -> String {
    let member_path = state.member_paths.get(pkg).unwrap();
    let features = match member_path == "" {
        true => solution_unit_sparse_features_text(state, result, pkg, target, rows, version),
        false => solution_unit_features_text(state, result, pkg, target),
    };
    match member_path == "" {
        true => append_solution_unit_row(out, state.names.get(pkg).unwrap(), version, registry_lib_target_shape(state.names.get(pkg).unwrap()), registry_profile(), features, solution_dep_names_text(state, index, result, pkg, target)),
        false => solution_member_units_text(workspace, workspace_root, state.names.get(pkg).unwrap(), version, member_manifest(workspace, workspace_root, member_path), workspace_profile(), features, solution_dep_names_text(state, index, result, pkg, target), out),
    }
}

fn register_selected_sparse_features(rows: [SparseIndexRow], state: WorkspaceIndexState, result: SolveResult) -> WorkspaceIndexState {
    match rows.len() == 0 {
        true => state,
        false => register_selected_sparse_features_tuple(rows.pop(), state, result),
    }
}

fn register_selected_sparse_features_tuple(popped: (SparseIndexRow, [SparseIndexRow]), state: WorkspaceIndexState, result: SolveResult) -> WorkspaceIndexState {
    let state = register_selected_sparse_features(popped.1, state, result);
    register_selected_sparse_row_features(popped.0, state, result)
}

fn register_selected_sparse_row_features(row: SparseIndexRow, state: WorkspaceIndexState, result: SolveResult) -> WorkspaceIndexState {
    match sparse_row_yanked(row) {
        true => state,
        false => match state.package_ids.get(sparse_row_name(row)) {
            Some(pkg) => match result.selected.get(pkg) {
                Some(_) => register_sparse_features(pkg, row, state),
                None => state,
            },
            None => state,
        },
    }
}

fn solution_units_text_from_packages(workspace: Tree, workspace_root: Path, state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, packages: [Int], out: String) -> String {
    match packages.len() == 0 {
        true => out,
        false => solution_units_text_from_packages_tuple(workspace, workspace_root, state, index, result, target, packages.pop(), out),
    }
}

fn solution_units_text_from_packages_tuple(workspace: Tree, workspace_root: Path, state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, popped: (Int, [Int]), out: String) -> String {
    let out = solution_units_text_for_package(workspace, workspace_root, state, index, result, target, popped.0, out);
    solution_units_text_from_packages(workspace, workspace_root, state, index, result, target, popped.1, out)
}

fn solution_units_text_for_package(workspace: Tree, workspace_root: Path, state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, pkg: Int, out: String) -> String {
    match result.selected.get(pkg) {
        Some(version) => match state.names.get(pkg).unwrap() == "__workspace__" {
            true => out,
            false => solution_units_text_for_selected_package(workspace, workspace_root, state, index, result, target, pkg, workspace_selected_version_text(state, pkg, version), out),
        },
        None => out,
    }
}

fn solution_units_text_for_selected_package(workspace: Tree, workspace_root: Path, state: WorkspaceIndexState, index: Index, result: SolveResult, target: String, pkg: Int, version: String, out: String) -> String {
    let member_path = state.member_paths.get(pkg).unwrap();
    let features = solution_unit_features_text(state, result, pkg, target);
    match member_path == "" {
        true => append_solution_unit_row(out, state.names.get(pkg).unwrap(), version, registry_lib_target_shape(state.names.get(pkg).unwrap()), registry_profile(), features, solution_dep_names_text(state, index, result, pkg, target)),
        false => solution_member_units_text(workspace, workspace_root, state.names.get(pkg).unwrap(), version, member_manifest(workspace, workspace_root, member_path), workspace_profile(), features, solution_dep_names_text(state, index, result, pkg, target), out),
    }
}

fn solution_member_units_text(workspace: Tree, workspace_root: Path, package: String, version: String, manifest: Tree, profile: CargoUnitProfile, features: String, deps: String, out: String) -> String {
    match manifest_doc(manifest).get("bin") {
        Some(bin_docs) => solution_bin_units_text(package, version, doc_as_docs(bin_docs), profile, features, deps, out),
        None => append_solution_unit_row(out, package, version, manifest_lib_target(manifest), profile, features, deps),
    }
}

fn solution_bin_units_text(package: String, version: String, bins: [Doc], profile: CargoUnitProfile, features: String, deps: String, out: String) -> String {
    match bins.len() == 0 {
        true => out,
        false => solution_bin_units_text_tuple(package, version, bins.pop(), profile, features, deps, out),
    }
}

fn solution_bin_units_text_tuple(package: String, version: String, popped: (Doc, [Doc]), profile: CargoUnitProfile, features: String, deps: String, out: String) -> String {
    let out = solution_bin_units_text(package, version, popped.1, profile, features, deps, out);
    append_solution_unit_row(out, package, version, bin_doc_target_shape(package, popped.0), profile, features, deps)
}

fn manifest_lib_target(manifest: Tree) -> CargoTargetShape {
    match manifest_doc(manifest).get("lib") {
        Some(lib) => manifest_explicit_lib_target(manifest, lib),
        None => lib_target(manifest),
    }
}

fn manifest_explicit_lib_target(manifest: Tree, lib: Doc) -> CargoTargetShape {
    let name = crate_name(package_name(manifest));
    let kind = explicit_lib_kind(lib);
    CargoTargetShape {
        name: name,
        kind: kind,
        source: doc_string_or(lib, "path", "src/lib.rs"),
        crate_type: kind,
        metadata_file: "lib" + name + ".rmeta",
        link_file: "lib" + name + ".rlib",
    }
}

fn explicit_lib_kind(lib: Doc) -> String {
    match doc_bool_or(lib, "proc-macro", false) {
        true => "proc-macro",
        false => match string_list_contains(doc_strings_or_empty(lib, "crate-type"), "cdylib") {
            true => "cdylib",
            false => "lib",
        },
    }
}

fn bin_doc_target_shape(package: String, bin: Doc) -> CargoTargetShape {
    let name = crate_name(doc_string_or(bin, "name", crate_name(package)));
    CargoTargetShape {
        name: name,
        kind: "bin",
        source: doc_string_or(bin, "path", "src/main.rs"),
        crate_type: "bin",
        metadata_file: name + ".rmeta",
        link_file: name,
    }
}

fn registry_lib_target_shape(package: String) -> CargoTargetShape {
    let name = crate_name(package);
    CargoTargetShape {
        name: name,
        kind: "lib",
        source: "src/lib.rs",
        crate_type: "lib",
        metadata_file: "lib" + name + ".rmeta",
        link_file: "lib" + name + ".rlib",
    }
}

fn string_list_contains(values: [String], needle: String) -> Bool {
    match values.len() == 0 {
        true => false,
        false => string_list_contains_tuple(values.pop(), needle),
    }
}

fn string_list_contains_tuple(popped: (String, [String]), needle: String) -> Bool {
    match popped.0 == needle {
        true => true,
        false => string_list_contains(popped.1, needle),
    }
}

fn workspace_profile() -> CargoUnitProfile {
    CargoUnitProfile {
        name: "dev",
        opt_level: "0",
        lto: "false",
        codegen_backend: "null",
        codegen_units: "null",
        debuginfo: "2",
        split_debuginfo: "unpacked",
        debug_assertions: "true",
        overflow_checks: "true",
        rpath: "false",
        incremental: "true",
        panic: "unwind",
        strip: "None",
    }
}

fn registry_profile() -> CargoUnitProfile {
    CargoUnitProfile {
        name: "dev",
        opt_level: "0",
        lto: "false",
        codegen_backend: "null",
        codegen_units: "null",
        debuginfo: "2",
        split_debuginfo: "unpacked",
        debug_assertions: "true",
        overflow_checks: "true",
        rpath: "false",
        incremental: "false",
        panic: "unwind",
        strip: "None",
    }
}

fn selected_pkg_contains(selected: Map<Int, Version>, pkg: Int) -> Bool {
    match selected.get(pkg) {
        Some(_) => true,
        None => false,
    }
}

fn solution_guard_is_parent(index: Index, guard_id: Int, clause_id: Int, parent: Int) -> Bool {
    index.guard_clause_ids.get(guard_id).unwrap() == clause_id
        && index.guard_pkgs.get(guard_id).unwrap() == parent
        && index.guard_tags.get(guard_id).unwrap() == "selected"
}

fn solution_clause_has_parent_guard(index: Index, parent: Int, clause_id: Int, guard_ids: [Int]) -> Bool {
    match guard_ids.len() == 0 {
        true => false,
        false => solution_clause_has_parent_guard_tuple(index, parent, clause_id, guard_ids.pop()),
    }
}

fn solution_clause_has_parent_guard_tuple(index: Index, parent: Int, clause_id: Int, popped: (Int, [Int])) -> Bool {
    match solution_guard_is_parent(index, popped.0, clause_id, parent) {
        true => true,
        false => solution_clause_has_parent_guard(index, parent, clause_id, popped.1),
    }
}

fn solution_dependency_clause_active(index: Index, result: SolveResult, parent: Int, clause_id: Int, target: String) -> Bool {
    match gate_active_id(index, clause_id, target)
        && selected_pkg_contains(result.selected, parent)
        && solution_clause_has_parent_guard(index, parent, clause_id, index.guard_ids)
        && index.consequent_tags.get(clause_id).unwrap() == "in_graph" {
        true => selected_pkg_contains(result.selected, index.consequent_pkgs.get(clause_id).unwrap()),
        false => false,
    }
}

pub fn solution_dep_names_text(state: WorkspaceIndexState, index: Index, result: SolveResult, parent: Int, target: String) -> String {
    solution_dep_names_text_from(state, index, result, parent, target, index.clause_ids, "")
}

fn solution_dep_names_text_from(state: WorkspaceIndexState, index: Index, result: SolveResult, parent: Int, target: String, clause_ids: [Int], out: String) -> String {
    match clause_ids.len() == 0 {
        true => out,
        false => solution_dep_names_text_tuple(state, index, result, parent, target, clause_ids.pop(), out),
    }
}

fn solution_dep_names_text_tuple(state: WorkspaceIndexState, index: Index, result: SolveResult, parent: Int, target: String, popped: (Int, [Int]), out: String) -> String {
    let out = match solution_dependency_clause_active(index, result, parent, popped.0, target) {
        true => append_dep_name(out, crate_name(state.names.get(index.consequent_pkgs.get(popped.0).unwrap()).unwrap())),
        false => out,
    };
    solution_dep_names_text_from(state, index, result, parent, target, popped.1, out)
}

fn append_dep_name(out: String, name: String) -> String {
    match out == "" {
        true => name,
        false => out + "," + name,
    }
}

fn solution_unit_features_text(state: WorkspaceIndexState, result: SolveResult, pkg: Int, target: String) -> String {
    solution_unit_root_default_feature(state, result, pkg, target, solution_unit_features(state, result.enabled_feature_ids, pkg, target, [])).join(",")
}

fn solution_unit_sparse_features_text(state: WorkspaceIndexState, result: SolveResult, pkg: Int, target: String, rows: [SparseIndexRow], version: String) -> String {
    let seeds = solution_unit_seed_features(state, result.enabled_feature_ids, pkg, []);
    match selected_sparse_row(rows, state.names.get(pkg).unwrap(), version) {
        Some(row) => sparse_row_filter_active_features(row, target, append_strings_unique(sparse_row_unit_features(row, target, seeds, []), seeds), []).join(","),
        None => seeds.join(","),
    }
}

fn solution_unit_seed_features(state: WorkspaceIndexState, feature_ids: [Int], pkg: Int, out: [String]) -> [String] {
    match feature_ids.len() == 0 {
        true => out,
        false => solution_unit_seed_features_tuple(state, feature_ids.pop(), pkg, out),
    }
}

fn solution_unit_seed_features_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), pkg: Int, out: [String]) -> [String] {
    let out = match state.feature_pkgs.get(popped.0).unwrap() == pkg {
        true => append_string_unique(out, unit_feature_name(state.feature_names.get(popped.0).unwrap())),
        false => out,
    };
    solution_unit_seed_features(state, popped.1, pkg, out)
}

pub fn selected_sparse_row(rows: [SparseIndexRow], name: String, version: String) -> Option<SparseIndexRow> {
    match rows.len() == 0 {
        true => None,
        false => selected_sparse_row_tuple(rows.pop(), name, version),
    }
}

fn selected_sparse_row_tuple(popped: (SparseIndexRow, [SparseIndexRow]), name: String, version: String) -> Option<SparseIndexRow> {
    match sparse_row_name(popped.0) == name && sparse_row_vers(popped.0) == version {
        true => Some(popped.0),
        false => selected_sparse_row(popped.1, name, version),
    }
}

fn sparse_row_unit_features(row: SparseIndexRow, target: String, features: [String], out: [String]) -> [String] {
    match features.len() == 0 {
        true => out,
        false => sparse_row_unit_features_tuple(row, target, features.pop(), out),
    }
}

fn sparse_row_unit_features_tuple(row: SparseIndexRow, target: String, popped: (String, [String]), out: [String]) -> [String] {
    let out = sparse_row_unit_features(row, target, popped.1, out);
    sparse_row_unit_feature_closure(row, target, popped.0, out)
}

fn sparse_row_unit_feature_closure(row: SparseIndexRow, target: String, feature: String, out: [String]) -> [String] {
    let feature_name = unit_feature_name(feature);
    match string_list_contains(out, feature_name) {
        true => out,
        false => sparse_row_unit_feature_enables(row, target, sparse_row_feature_enables_or_empty(row, feature_name), out.push(feature_name)),
    }
}

fn sparse_row_feature_enables_or_empty(row: SparseIndexRow, feature: String) -> [String] {
    match row.features.get(feature) {
        Some(enables) => enables,
        None => [],
    }
}

fn sparse_row_unit_feature_enables(row: SparseIndexRow, target: String, enables: [String], out: [String]) -> [String] {
    match enables.len() == 0 {
        true => out,
        false => sparse_row_unit_feature_enables_tuple(row, target, enables.pop(), out),
    }
}

fn sparse_row_unit_feature_enables_tuple(row: SparseIndexRow, target: String, popped: (String, [String]), out: [String]) -> [String] {
    let out = sparse_row_unit_feature_enables(row, target, popped.1, out);
    let local = local_feature_name_from_enable(popped.0);
    match local == "" {
        true => out,
        false => match sparse_feature_target_active(row, local, target) {
            true => sparse_row_unit_feature_closure(row, target, local, out),
            false => out,
        },
    }
}

fn sparse_feature_target_active(row: SparseIndexRow, feature: String, target: String) -> Bool {
    match sparse_feature_target(row, feature) {
        Some(expr) => target_matches(expr, target),
        None => match feature.contains("windows") {
            true => target_matches("cfg(windows)", target),
            false => true,
        },
    }
}

fn sparse_row_filter_active_features(row: SparseIndexRow, target: String, features: [String], out: [String]) -> [String] {
    match features.len() == 0 {
        true => out,
        false => sparse_row_filter_active_features_tuple(row, target, features.pop(), out),
    }
}

fn sparse_row_filter_active_features_tuple(row: SparseIndexRow, target: String, popped: (String, [String]), out: [String]) -> [String] {
    let out = sparse_row_filter_active_features(row, target, popped.1, out);
    match sparse_feature_target_active(row, popped.0, target) {
        true => append_string_unique(out, popped.0),
        false => out,
    }
}

fn solution_unit_root_default_feature(state: WorkspaceIndexState, result: SolveResult, pkg: Int, target: String, out: [String]) -> [String] {
    match state.member_paths.get(pkg).unwrap() == "" {
        true => out,
        false => match result.selected.get(pkg) {
            Some(_) => match feature_id_opt(state, pkg, "default") {
                Some(_) => solution_unit_feature_closure(state, pkg, "default", target, out),
                None => out,
            },
            None => out,
        },
    }
}

fn solution_unit_features(state: WorkspaceIndexState, feature_ids: [Int], pkg: Int, target: String, out: [String]) -> [String] {
    match feature_ids.len() == 0 {
        true => out,
        false => solution_unit_features_tuple(state, feature_ids.pop(), pkg, target, out),
    }
}

fn solution_unit_features_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), pkg: Int, target: String, out: [String]) -> [String] {
    let out = match state.feature_pkgs.get(popped.0).unwrap() == pkg {
        true => solution_unit_feature_closure(state, pkg, state.feature_names.get(popped.0).unwrap(), target, out),
        false => out,
    };
    solution_unit_features(state, popped.1, pkg, target, out)
}

fn solution_unit_feature_closure(state: WorkspaceIndexState, pkg: Int, feature: String, target: String, out: [String]) -> [String] {
    let feature_name = unit_feature_name(feature);
    match string_list_contains(out, feature_name) {
        true => out,
        false => match feature_id_opt(state, pkg, feature) {
            Some(id) => solution_unit_feature_enables_text(state, pkg, state.feature_enables.get(id).unwrap(), target, out.push(feature_name)),
            None => out.push(feature_name),
        },
    }
}

fn solution_unit_feature_enables_text(state: WorkspaceIndexState, pkg: Int, enables: String, target: String, out: [String]) -> [String] {
    match enables == "" {
        true => out,
        false => match enables.contains("\n") {
            true => solution_unit_feature_enable_text(state, pkg, enables.before("\n"), target, solution_unit_feature_enables_text(state, pkg, enables.after("\n"), target, out)),
            false => solution_unit_feature_enable_text(state, pkg, enables, target, out),
        },
    }
}

fn solution_unit_feature_enable_text(state: WorkspaceIndexState, pkg: Int, enable: String, target: String, out: [String]) -> [String] {
    let local = local_feature_name_from_enable(enable);
    match local == "" {
        true => out,
        false => match feature_target_active(state, pkg, local, target) {
            true => solution_unit_feature_closure(state, pkg, local, target, out),
            false => out,
        },
    }
}

fn feature_target_active(state: WorkspaceIndexState, pkg: Int, feature: String, target: String) -> Bool {
    match state.feature_targets.get(feature_key(state, pkg, feature)) {
        Some(expr) => target_matches(expr, target),
        None => true,
    }
}

fn unit_feature_name(feature: String) -> String {
    match feature.contains(":") {
        true => feature.after(":"),
        false => feature,
    }
}

fn append_solution_unit_row(out: String, package: String, version: String, target: CargoTargetShape, profile: CargoUnitProfile, features: String, deps: String) -> String {
    let row = package + "\t"
        + version + "\t"
        + target.name + "\t"
        + target.kind + "\t"
        + target.crate_type + "\t"
        + target.source + "\t"
        + "build\t\t"
        + features + "\t"
        + profile.name + "\t"
        + profile.opt_level + "\t"
        + profile.lto + "\t"
        + profile.codegen_backend + "\t"
        + profile.codegen_units + "\t"
        + profile.debuginfo + "\t"
        + profile.split_debuginfo + "\t"
        + profile.debug_assertions + "\t"
        + profile.overflow_checks + "\t"
        + profile.rpath + "\t"
        + profile.incremental + "\t"
        + profile.panic + "\t"
        + profile.strip + "\t"
        + deps;
    match out == "" {
        true => row,
        false => out + "\n" + row,
    }
}

fn selected_workspace_state_versions_text_from(state: WorkspaceIndexState, packages: [Int], selected: Map<Int, Version>, out: String) -> String {
    match packages.len() == 0 {
        true => out,
        false => selected_workspace_state_versions_text_tuple(state, packages.pop(), selected, out),
    }
}

fn selected_workspace_state_versions_text_tuple(state: WorkspaceIndexState, popped: (Int, [Int]), selected: Map<Int, Version>, out: String) -> String {
    selected_workspace_state_versions_text_one(state, popped.0, popped.1, selected, out)
}

fn selected_workspace_state_versions_text_one(state: WorkspaceIndexState, pkg: Int, rest: [Int], selected: Map<Int, Version>, out: String) -> String {
    let next = match selected.get(pkg) {
        Some(version) => append_selected_workspace_state_version(out, state.names.get(pkg).unwrap(), workspace_selected_version_text(state, pkg, version)),
        None => out,
    };
    selected_workspace_state_versions_text_from(state, rest, selected, next)
}

fn append_selected_workspace_state_version(out: String, name: String, version: String) -> String {
    match out == "" {
        true => name + " " + version,
        false => out + "\n" + name + " " + version,
    }
}

fn workspace_state_version_text(state: WorkspaceIndexState, pkg: Int) -> String {
    workspace_state_version_text_from(state, pkg, state.version_ids)
}

fn workspace_state_version_text_from(state: WorkspaceIndexState, pkg: Int, version_ids: [Int]) -> String {
    match version_ids.len() == 0 {
        true => "",
        false => workspace_state_version_text_tuple(state, pkg, version_ids.pop()),
    }
}

fn workspace_state_version_text_tuple(state: WorkspaceIndexState, pkg: Int, popped: (Int, [Int])) -> String {
    workspace_state_version_text_one(state, pkg, popped.0, popped.1)
}

fn workspace_state_version_text_one(state: WorkspaceIndexState, pkg: Int, version_id: Int, rest: [Int]) -> String {
    match state.version_pkgs.get(version_id).unwrap() == pkg {
        true => state.version_values.get(version_id).unwrap(),
        false => workspace_state_version_text_from(state, pkg, rest),
    }
}

fn workspace_selected_version_text(state: WorkspaceIndexState, pkg: Int, selected: Version) -> String {
    workspace_selected_version_text_from(state, pkg, selected, state.version_ids)
}

pub fn selected_version_text(state: WorkspaceIndexState, result: SolveResult, package: String) -> String {
    let pkg = state.package_ids.get(package).unwrap();
    workspace_selected_version_text(state, pkg, result.selected.get(pkg).unwrap())
}

fn workspace_selected_version_text_from(state: WorkspaceIndexState, pkg: Int, selected: Version, version_ids: [Int]) -> String {
    match version_ids.len() == 0 {
        true => "",
        false => workspace_selected_version_text_tuple(state, pkg, selected, version_ids.pop()),
    }
}

fn workspace_selected_version_text_tuple(state: WorkspaceIndexState, pkg: Int, selected: Version, popped: (Int, [Int])) -> String {
    workspace_selected_version_text_one(state, pkg, selected, popped.0, popped.1)
}

fn workspace_selected_version_text_one(state: WorkspaceIndexState, pkg: Int, selected: Version, version_id: Int, rest: [Int]) -> String {
    let row_text = state.version_values.get(version_id).unwrap();
    match state.version_pkgs.get(version_id).unwrap() == pkg && VersionSet::from_req("=" + row_text).contains(selected) {
        true => row_text,
        false => workspace_selected_version_text_from(state, pkg, selected, rest),
    }
}

pub fn package_of(manifest: Tree, workspace: Tree, manifest_path: String) -> CargoPackage {
    CargoPackage {
        name: package_name(manifest),
        version: package_version(manifest),
        edition: package_edition(manifest, workspace),
        manifest: manifest_path,
    }
}

fn dependency_table(manifest: Tree, kind: String) -> Doc {
    manifest_doc(manifest).get(dependency_table_name(kind)).unwrap()
}

fn dependency_table_opt(manifest: Tree, kind: String) -> Option<Doc> {
    manifest_doc(manifest).get(dependency_table_name(kind))
}

fn dependency_table_name(kind: String) -> String {
    match kind == "build" {
        true => "build-dependencies",
        false => match kind == "dev" {
            true => "dev-dependencies",
            false => "dependencies",
        },
    }
}

fn dependency_doc(manifest: Tree, name: String, kind: String) -> Doc {
    dependency_table(manifest, kind).get(name).unwrap()
}

pub fn dependency_names_text(manifest: Tree, kind: String) -> String {
    dependency_table(manifest, kind).keys().join("\n")
}

fn dependency_names(manifest: Tree, kind: String) -> [String] {
    match dependency_table_opt(manifest, kind) {
        Some(table) => table.keys(),
        None => [],
    }
}

fn register_workspace_direct_deps(workspace: Tree, workspace_root: Path, members: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match members.len() == 0 {
        true => state,
        false => register_workspace_direct_deps_tuple(workspace, workspace_root, members.pop(), state),
    }
}

fn register_workspace_direct_deps_tuple(workspace: Tree, workspace_root: Path, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_workspace_direct_deps(workspace, workspace_root, popped.1, state);
    let manifest = member_manifest(workspace, workspace_root, popped.0);
    let parent_pkg = state.package_ids.get(package_name(manifest)).unwrap();
    let parent_version = package_version_in_workspace(manifest, workspace);
    let state = register_workspace_kind_deps(workspace, manifest, state, parent_pkg, parent_version, "normal");
    let state = register_workspace_kind_deps(workspace, manifest, state, parent_pkg, parent_version, "build");
    register_workspace_kind_deps(workspace, manifest, state, parent_pkg, parent_version, "dev")
}

fn register_workspace_kind_deps(workspace: Tree, manifest: Tree, state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, kind: String) -> WorkspaceIndexState {
    register_workspace_dep_names(workspace, manifest, dependency_names(manifest, kind), state, parent_pkg, parent_version, kind)
}

fn register_workspace_dep_names(workspace: Tree, manifest: Tree, names: [String], state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, kind: String) -> WorkspaceIndexState {
    match names.len() == 0 {
        true => state,
        false => register_workspace_dep_names_tuple(workspace, manifest, names.pop(), state, parent_pkg, parent_version, kind),
    }
}

fn register_workspace_dep_names_tuple(workspace: Tree, manifest: Tree, popped: (String, [String]), state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, kind: String) -> WorkspaceIndexState {
    let state = register_workspace_dep_names(workspace, manifest, popped.1, state, parent_pkg, parent_version, kind);
    register_workspace_dep_name(workspace, manifest, state, parent_pkg, parent_version, popped.0, kind)
}

fn register_workspace_dep_name(workspace: Tree, manifest: Tree, state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_name: String, kind: String) -> WorkspaceIndexState {
    let dep = dependency_doc(manifest, dep_name, kind);
    let package_name = dependency_package_name(dep, dep_name);
    match state.package_ids.get(package_name) {
        Some(dep_pkg) => register_workspace_known_dep(workspace, manifest, state, parent_pkg, parent_version, dep_name, dep_pkg, kind),
        None => state,
    }
}

fn register_workspace_known_dep(workspace: Tree, manifest: Tree, state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_name: String, dep_pkg: Int, kind: String) -> WorkspaceIndexState {
    let dep = dependency_doc(manifest, dep_name, kind);
    match dependency_optional(dep) {
        true => state,
        false => register_workspace_known_required_dep(workspace, state, parent_pkg, parent_version, dep_name, dep_pkg, kind, dep),
    }
}

fn register_workspace_known_required_dep(workspace: Tree, state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_name: String, dep_pkg: Int, kind: String, dep: Doc) -> WorkspaceIndexState {
    let workspace_dep = dependency_is_workspace(dep);
    let state = add_workspace_required_dep_clauses(state, parent_pkg, parent_version, dep_pkg, dependency_req_or_any(dependency_version_req(dep, workspace, dep_name, workspace_dep)), kind);
    add_dependency_requested_feature_clauses(state, parent_pkg, parent_version, dep_pkg, dependency_requested_features(dep, workspace, dep_name, workspace_dep), kind, None)
}

fn dependency_req_or_any(req: String) -> String {
    match req == "" {
        true => "*",
        false => req,
    }
}

fn target_dependency_table(manifest: Tree, target: String, kind: String) -> Doc {
    manifest_doc(manifest)
        .get("target")
        .unwrap()
        .get(target)
        .unwrap()
        .get(dependency_table_name(kind))
        .unwrap()
}

fn target_dependency_doc(manifest: Tree, target: String, name: String, kind: String) -> Doc {
    target_dependency_table(manifest, target, kind).get(name).unwrap()
}

fn cfg_true() -> Doc {
    cfg("cfg(all())")
}

fn workspace_dependency_version(workspace: Tree, name: String) -> String {
    let dep = workspace_dependency_doc(workspace, name);
    match dep.is_map() {
        true => doc_string_or_empty(dep, "version"),
        false => doc_as_string(dep),
    }
}

fn workspace_dependency_path(workspace: Tree, name: String) -> String {
    dependency_doc_string_or_empty(workspace_dependency_doc(workspace, name), "path")
}

fn workspace_dependency_default_features(workspace: Tree, name: String) -> Bool {
    dependency_doc_bool_or(workspace_dependency_doc(workspace, name), "default-features", true)
}

fn workspace_dependency_features(workspace: Tree, name: String) -> [String] {
    dependency_doc_strings_or_empty(workspace_dependency_doc(workspace, name), "features")
}

fn dependency_version_req(dep: Doc, workspace: Tree, name: String, workspace_dep: Bool) -> String {
    match workspace_dep {
        true => workspace_dependency_version(workspace, name),
        false => match dep.is_map() {
            true => doc_string_or_empty(dep, "version"),
            false => doc_as_string(dep),
        },
    }
}

fn dependency_path(dep: Doc, workspace: Tree, name: String, workspace_dep: Bool) -> String {
    match workspace_dep {
        true => workspace_dependency_path(workspace, name),
        false => dependency_doc_string_or_empty(dep, "path"),
    }
}

fn dependency_is_workspace(dep: Doc) -> Bool {
    dependency_doc_bool_or(dep, "workspace", false)
}

fn inherited_default_features(workspace: Tree, name: String, workspace_dep: Bool) -> Bool {
    match workspace_dep {
        true => workspace_dependency_default_features(workspace, name),
        false => true,
    }
}

fn dependency_default_features(dep: Doc, workspace: Tree, name: String, workspace_dep: Bool) -> Bool {
    dependency_doc_bool_or(dep, "default-features", inherited_default_features(workspace, name, workspace_dep))
}

fn dependency_optional(dep: Doc) -> Bool {
    dependency_doc_bool_or(dep, "optional", false)
}

fn dependency_features(dep: Doc) -> [String] {
    dependency_doc_strings_or_empty(dep, "features")
}

fn dependency_features_inherited(dep: Doc, workspace: Tree, name: String, workspace_dep: Bool) -> [String] {
    match workspace_dep {
        true => append_strings_unique(workspace_dependency_features(workspace, name), dependency_features(dep)),
        false => dependency_features(dep),
    }
}

fn dependency_requested_features(dep: Doc, workspace: Tree, name: String, workspace_dep: Bool) -> [String] {
    let features = dependency_features_inherited(dep, workspace, name, workspace_dep);
    match dependency_default_features(dep, workspace, name, workspace_dep) {
        true => append_string_unique(features, "default"),
        false => features,
    }
}

fn append_strings_unique(values: [String], extra: [String]) -> [String] {
    match extra.len() == 0 {
        true => values,
        false => append_strings_unique_tuple(values, extra.pop()),
    }
}

fn append_strings_unique_tuple(values: [String], popped: (String, [String])) -> [String] {
    append_strings_unique(append_string_unique(values, popped.0), popped.1)
}

fn append_string_unique(values: [String], value: String) -> [String] {
    match string_list_contains(values, value) {
        true => values,
        false => values.push(value),
    }
}

fn dependency_package_name(dep: Doc, name: String) -> String {
    match dep.is_map() {
        true => doc_string_or(dep, "package", name),
        false => name,
    }
}

pub fn parse_sparse_jsonl(text: String) -> [SparseIndexRow] {
    parse_sparse_jsonl_into(text, [])
}

pub fn workspace_sparse_row_count(sparse_jsonl: String) -> Int {
    parse_sparse_jsonl(sparse_jsonl).len()
}

pub fn sparse_row_rt_multi_thread_feature_debug(row_json: String, target: String) -> String {
    sparse_row_unit_features(parse_sparse_row(row_json), target, ["rt-multi-thread"], []).join(",")
}

pub fn sparse_row_tokio_ring8_feature_debug(row_json: String, target: String) -> String {
    let seeds = ["io-util", "rt", "rt-multi-thread", "macros", "net", "default"];
    let row = parse_sparse_row(row_json);
    sparse_row_filter_active_features(row, target, append_strings_unique(sparse_row_unit_features(row, target, seeds, []), seeds), []).join(",")
}

fn parse_sparse_jsonl_into(text: String, out: [SparseIndexRow]) -> [SparseIndexRow] {
    match text == "" {
        true => out,
        false => match text.contains("\n") {
            true => parse_sparse_jsonl_line(text.before("\n"), text.after("\n"), out),
            false => out.push(parse_sparse_row(text)),
        },
    }
}

fn parse_sparse_jsonl_line(line: String, rest: String, out: [SparseIndexRow]) -> [SparseIndexRow] {
    let next = match line == "" {
        true => out,
        false => out.push(parse_sparse_row(line)),
    };
    parse_sparse_jsonl_into(rest, next)
}

fn parse_sparse_row(line: String) -> SparseIndexRow {
    let row: SparseIndexRow = json_typed(line);
    row
}

fn sparse_row_name(row: SparseIndexRow) -> String {
    row.name
}

fn sparse_row_vers(row: SparseIndexRow) -> String {
    row.vers
}

fn sparse_row_deps(row: SparseIndexRow) -> [SparseIndexDep] {
    row.deps
}

fn sparse_row_feature_names(row: SparseIndexRow) -> [String] {
    row.features.keys()
}

fn sparse_feature_enables(row: SparseIndexRow, feature: String) -> [String] {
    row.features.get(feature).unwrap()
}

fn sparse_row_yanked(row: SparseIndexRow) -> Bool {
    row.yanked
}

pub fn detailed_dependency_of(
    manifest: Tree,
    workspace: Tree,
    name: String,
    kind: String,
) -> CargoDependencyDecl {
    let dep = dependency_doc(manifest, name, kind);
    let workspace_dep = dependency_is_workspace(dep);
    let version_req = dependency_version_req(dep, workspace, name, workspace_dep);
    let path = dependency_path(dep, workspace, name, workspace_dep);
    let default_features = dependency_default_features(dep, workspace, name, workspace_dep);
    CargoDependencyDecl {
        name: name,
        kind: kind,
        target: "",
        cfg: cfg_true(),
        version_req: version_req,
        path: path,
        workspace: workspace_dep,
        optional: dependency_optional(dep),
        default_features: default_features,
        features: dependency_features_inherited(dep, workspace, name, workspace_dep),
    }
}

pub fn detailed_target_dependency_of(
    manifest: Tree,
    workspace: Tree,
    target: String,
    name: String,
    kind: String,
) -> CargoDependencyDecl {
    let dep = target_dependency_doc(manifest, target, name, kind);
    let workspace_dep = dependency_is_workspace(dep);
    let version_req = dependency_version_req(dep, workspace, name, workspace_dep);
    let path = dependency_path(dep, workspace, name, workspace_dep);
    let default_features = dependency_default_features(dep, workspace, name, workspace_dep);
    CargoDependencyDecl {
        name: name,
        kind: kind,
        target: target,
        cfg: cfg(target),
        version_req: version_req,
        path: path,
        workspace: workspace_dep,
        optional: dependency_optional(dep),
        default_features: default_features,
        features: dependency_features_inherited(dep, workspace, name, workspace_dep),
    }
}

pub fn version_dependency_of(manifest: Tree, name: String, kind: String) -> CargoDependencyDecl {
    let dep = dependency_doc(manifest, name, kind);
    let version_req = doc_as_string(dep);
    CargoDependencyDecl {
        name: name,
        kind: kind,
        target: "",
        cfg: cfg_true(),
        version_req: version_req,
        path: "",
        workspace: false,
        optional: false,
        default_features: true,
        features: [],
    }
}

fn lib_target(manifest: Tree) -> CargoTargetShape {
    let name = crate_name(package_name(manifest));
    CargoTargetShape {
        name: name,
        kind: "lib",
        source: "src/lib.rs",
        crate_type: "lib",
        metadata_file: "lib" + name + ".rmeta",
        link_file: "lib" + name + ".rlib",
    }
}

pub fn lib_target_shape(manifest: Tree) -> CargoTargetShape {
    lib_target(manifest)
}

pub fn proc_macro_target_shape(manifest: Tree) -> CargoTargetShape {
    let name = crate_name(package_name(manifest));
    let _proc_macro: Bool = manifest_doc(manifest).get("lib").unwrap().get("proc-macro").unwrap();
    CargoTargetShape {
        name: name,
        kind: "proc-macro",
        source: "src/lib.rs",
        crate_type: "proc-macro",
        metadata_file: "lib" + name + ".rmeta",
        link_file: "lib" + name + ".rlib",
    }
}

fn build_script_target() -> CargoTargetShape {
    CargoTargetShape {
        name: "build_script_build",
        kind: "build-script",
        source: "build.rs",
        crate_type: "bin",
        metadata_file: "build_script_build.rmeta",
        link_file: "build_script",
    }
}

pub fn build_script_target_shape(manifest: Tree) -> CargoTargetShape {
    build_script_target()
}

fn bin_target(manifest: Tree) -> CargoTargetShape {
    let name = crate_name(package_name(manifest));
    CargoTargetShape {
        name: name,
        kind: "bin",
        source: "src/main.rs",
        crate_type: "bin",
        metadata_file: name + ".rmeta",
        link_file: name,
    }
}

pub fn bin_target_shape(manifest: Tree) -> CargoTargetShape {
    bin_target(manifest)
}

pub fn target_shapes_array_gap() -> String {
    "target shape records are derivable one at a time, but returning [CargoTargetShape] currently renders as a non-array handle."
}

pub fn problem_of_member(root_pkg: Int, root_default_feature: Int) -> Problem {
    Problem {
        root_pkg: root_pkg,
        root_req: VersionSet::from_req("*"),
        root_features: [],
        root_default_feature: root_default_feature,
        root_default_features: true,
    }
}

pub fn resolved_unit_adaptation_gap() -> String {
    "Ring-scale solution unit rows are emitted from the composed workspace+sparse solve; artifact-producing crate.vix builds remain fixture-scoped because real source trees and feature-name UnitTargetTable emission are not complete."
}
