use vix::{Tree, Path, Version, VersionSet, Map};
use rodin::{Index, Problem, SolveResult, gate_active_id, solve, solve_selected_names, solve_selected_versions_text};

struct CargoPackage {
    name: String,
    version: String,
    edition: String,
    manifest: String,
}

struct CargoDependencyDecl {
    name: String,
    kind: String,
    target: String,
    cfg: Doc,
    version_req: String,
    path: String,
    workspace: Bool,
    optional: Bool,
    default_features: Bool,
    features: [String],
}

pub struct CargoTargetShape {
    name: String,
    kind: String,
    source: String,
    crate_type: String,
    metadata_file: String,
    link_file: String,
}

struct CargoUnitProfile {
    name: String,
    opt_level: String,
    lto: String,
    codegen_backend: String,
    codegen_units: String,
    debuginfo: String,
    split_debuginfo: String,
    debug_assertions: String,
    overflow_checks: String,
    rpath: String,
    incremental: String,
    panic: String,
    strip: String,
}

pub struct WorkspaceIndexState {
    packages: [Int],
    package_ids: Map<String, Int>,
    member_paths: Map<Int, String>,
    names: Map<Int, String>,
    version_ids: [Int],
    version_pkgs: Map<Int, Int>,
    version_values: Map<Int, String>,
    clause_ids: [Int],
    guard_ids: [Int],
    guard_clause_ids: Map<Int, Int>,
    guard_tags: Map<Int, String>,
    guard_kinds: Map<Int, Int>,
    guard_pkgs: Map<Int, Int>,
    guard_version_values: Map<Int, String>,
    guard_features: Map<Int, Int>,
    consequent_tags: Map<Int, String>,
    consequent_pkgs: Map<Int, Int>,
    consequent_version_sets: Map<Int, VersionSet>,
    consequent_req_texts: Map<Int, String>,
    consequent_features: Map<Int, Int>,
    gate_kinds: Map<Int, String>,
    gate_targets: Map<Int, String>,
    feature_ids: [Int],
    feature_keys: Map<String, Int>,
    feature_pkgs: Map<Int, Int>,
    feature_names: Map<Int, String>,
    feature_enables: Map<Int, String>,
    feature_targets: Map<String, String>,
    next_pkg: Int,
    next_version: Int,
    next_clause: Int,
    next_guard: Int,
    next_feature: Int,
}

pub struct SparseIndexRow {
    name: String,
    vers: String,
    deps: [SparseIndexDep],
    cksum: String,
    features: Map<String, [String]>,
    yanked: Bool,
    pubtime: String,
}

pub struct SparseIndexDep {
    name: String,
    package: String,
    req: String,
    kind: String,
    target: String,
    optional: Bool,
    default_features: Bool,
    features: [String],
}

fn manifest_doc(manifest: Tree) -> Doc {
    toml(manifest / p"Cargo.toml")
}

fn package_doc(manifest: Tree) -> Doc {
    manifest_doc(manifest).get("package").unwrap()
}

fn workspace_doc(workspace: Tree) -> Doc {
    manifest_doc(workspace).get("workspace").unwrap()
}

fn workspace_package_doc(workspace: Tree) -> Doc {
    workspace_doc(workspace).get("package").unwrap()
}

fn workspace_dependency_doc(workspace: Tree, name: String) -> Doc {
    workspace_doc(workspace).get("dependencies").unwrap().get(name).unwrap()
}

fn doc_string(doc: Doc, key: String) -> String {
    doc.get(key).unwrap()
}

fn doc_string_or_empty(doc: Doc, key: String) -> String {
    match doc.get(key) {
        Some(value) => doc_as_string(value),
        None => "",
    }
}

fn doc_string_or(doc: Doc, key: String, fallback: String) -> String {
    match doc.get(key) {
        Some(value) => doc_as_string(value),
        None => fallback,
    }
}

fn doc_bool_or(doc: Doc, key: String, fallback: Bool) -> Bool {
    match doc.get(key) {
        Some(value) => doc_as_bool(value),
        None => fallback,
    }
}

fn doc_strings_or_empty(doc: Doc, key: String) -> [String] {
    match doc.get(key) {
        Some(value) => doc_as_strings(value),
        None => [],
    }
}

fn dependency_doc_string_or_empty(dep: Doc, key: String) -> String {
    match dep.is_map() {
        true => doc_string_or_empty(dep, key),
        false => "",
    }
}

fn dependency_doc_bool_or(dep: Doc, key: String, fallback: Bool) -> Bool {
    match dep.is_map() {
        true => doc_bool_or(dep, key, fallback),
        false => fallback,
    }
}

fn dependency_doc_strings_or_empty(dep: Doc, key: String) -> [String] {
    match dep.is_map() {
        true => doc_strings_or_empty(dep, key),
        false => [],
    }
}

fn doc_as_string(doc: Doc) -> String {
    doc
}

fn doc_as_bool(doc: Doc) -> Bool {
    doc
}

fn doc_as_strings(doc: Doc) -> [String] {
    doc
}

fn doc_as_docs(doc: Doc) -> [Doc] {
    doc
}

pub fn crate_name(package_name: String) -> String {
    match package_name.contains("-") {
        true => crate_name(package_name.before("-") + "_" + package_name.after("-")),
        false => package_name,
    }
}

pub fn package_name(manifest: Tree) -> String {
    doc_string(package_doc(manifest), "name")
}

fn package_version(manifest: Tree) -> String {
    doc_string(package_doc(manifest), "version")
}

pub fn package_version_in_workspace(manifest: Tree, workspace: Tree) -> String {
    inherited_package_string(manifest, workspace, "version")
}

fn inherited_workspace_package_string(field: Doc, workspace: Tree, key: String) -> String {
    let _workspace: Bool = field.get("workspace").unwrap();
    doc_string(workspace_package_doc(workspace), key)
}

fn inherited_package_string(manifest: Tree, workspace: Tree, key: String) -> String {
    let field = package_doc(manifest).get(key).unwrap();
    match field.is_map() {
        true => inherited_workspace_package_string(field, workspace, key),
        false => doc_as_string(field),
    }
}

fn package_edition(manifest: Tree, workspace: Tree) -> String {
    inherited_package_string(manifest, workspace, "edition")
}

pub fn package_rust_version(manifest: Tree, workspace: Tree) -> String {
    inherited_package_string(manifest, workspace, "rust-version")
}

pub fn package_license(manifest: Tree, workspace: Tree) -> String {
    inherited_package_string(manifest, workspace, "license")
}

pub fn package_repository(manifest: Tree, workspace: Tree) -> String {
    inherited_package_string(manifest, workspace, "repository")
}

fn member_from_manifest_path(path: Path) -> String {
    path.to_string().before("/Cargo.toml")
}

pub fn member_manifest_path(workspace_root: Path, member: String) -> String {
    member_path(workspace_root, member).join("Cargo.toml").to_string()
}

fn member_path(workspace_root: Path, member: String) -> Path {
    match member.contains("/") {
        true => member_path(workspace_root.join(member.before("/")), member.after("/")),
        false => workspace_root.join(member),
    }
}

fn workspace_member_entries(workspace: Tree) -> [String] {
    workspace_doc(workspace).get("members").unwrap()
}

fn workspace_member_glob_pattern(member: String) -> String {
    member + "/Cargo.toml"
}

fn workspace_members_from_manifest_paths(paths: [Path], out: [String]) -> [String] {
    match paths.len() == 0 {
        true => out,
        false => workspace_members_from_manifest_paths_tuple(paths.pop(), out),
    }
}

fn workspace_members_from_manifest_paths_tuple(popped: (Path, [Path]), out: [String]) -> [String] {
    let out = workspace_members_from_manifest_paths(popped.1, out);
    out.push(member_from_manifest_path(popped.0))
}

fn workspace_members_from_glob(workspace: Tree, member: String, out: [String]) -> [String] {
    workspace_members_from_manifest_paths(workspace.glob(workspace_member_glob_pattern(member)), out)
}

fn workspace_members_from_entry(workspace: Tree, member: String, out: [String]) -> [String] {
    match member.contains("*") {
        true => workspace_members_from_glob(workspace, member, out),
        false => out.push(member),
    }
}

fn workspace_members_from_entries(workspace: Tree, entries: [String], out: [String]) -> [String] {
    match entries.len() == 0 {
        true => out,
        false => workspace_members_from_entries_tuple(workspace, entries.pop(), out),
    }
}

fn workspace_members_from_entries_tuple(workspace: Tree, popped: (String, [String]), out: [String]) -> [String] {
    let out = workspace_members_from_entries(workspace, popped.1, out);
    workspace_members_from_entry(workspace, popped.0, out)
}

pub fn workspace_members(workspace: Tree) -> [String] {
    workspace_members_from_entries(workspace, workspace_member_entries(workspace), [])
}

pub fn workspace_member_count(workspace: Tree) -> Int {
    workspace_members(workspace).len()
}

pub fn workspace_members_text(workspace: Tree) -> String {
    workspace_members(workspace).join("\n")
}

fn empty_workspace_index_state() -> WorkspaceIndexState {
    let package_ids: Map<String, Int> = {};
    let member_paths: Map<Int, String> = {};
    let names: Map<Int, String> = {};
    let version_pkgs: Map<Int, Int> = {};
    let version_values: Map<Int, String> = {};
    let guard_clause_ids: Map<Int, Int> = {};
    let guard_tags: Map<Int, String> = {};
    let guard_kinds: Map<Int, Int> = {};
    let guard_pkgs: Map<Int, Int> = {};
    let guard_version_values: Map<Int, String> = {};
    let guard_features: Map<Int, Int> = {};
    let consequent_tags: Map<Int, String> = {};
    let consequent_pkgs: Map<Int, Int> = {};
    let consequent_version_sets: Map<Int, VersionSet> = {};
    let consequent_req_texts: Map<Int, String> = {};
    let consequent_features: Map<Int, Int> = {};
    let gate_kinds: Map<Int, String> = {};
    let gate_targets: Map<Int, String> = {};
    let feature_keys: Map<String, Int> = {};
    let feature_pkgs: Map<Int, Int> = {};
    let feature_names: Map<Int, String> = {};
    let feature_enables: Map<Int, String> = {};
    let feature_targets: Map<String, String> = {};
    WorkspaceIndexState {
        packages: [],
        package_ids: package_ids,
        member_paths: member_paths,
        names: names,
        version_ids: [],
        version_pkgs: version_pkgs,
        version_values: version_values,
        clause_ids: [],
        guard_ids: [],
        guard_clause_ids: guard_clause_ids,
        guard_tags: guard_tags,
        guard_kinds: guard_kinds,
        guard_pkgs: guard_pkgs,
        guard_version_values: guard_version_values,
        guard_features: guard_features,
        consequent_tags: consequent_tags,
        consequent_pkgs: consequent_pkgs,
        consequent_version_sets: consequent_version_sets,
        consequent_req_texts: consequent_req_texts,
        consequent_features: consequent_features,
        gate_kinds: gate_kinds,
        gate_targets: gate_targets,
        feature_ids: [],
        feature_keys: feature_keys,
        feature_pkgs: feature_pkgs,
        feature_names: feature_names,
        feature_enables: feature_enables,
        feature_targets: feature_targets,
        next_pkg: 0,
        next_version: 0,
        next_clause: 0,
        next_guard: 0,
        next_feature: 1,
    }
}

fn register_workspace_pseudo_root(state: WorkspaceIndexState) -> WorkspaceIndexState {
    register_workspace_package(state, "__workspace__", "0.0.0", "")
}

pub fn member_manifest(workspace: Tree, workspace_root: Path, member: String) -> Tree {
    workspace / member_path(workspace_root, member)
}

pub fn workspace_projected_member_package_name(workspace: Tree, workspace_root: Path, member: String) -> String {
    package_name(member_manifest(workspace, workspace_root, member))
}

fn register_workspace_members(workspace: Tree, workspace_root: Path, members: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match members.len() == 0 {
        true => state,
        false => register_workspace_members_tuple(workspace, workspace_root, members.pop(), state),
    }
}

fn register_workspace_members_tuple(workspace: Tree, workspace_root: Path, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_workspace_members(workspace, workspace_root, popped.1, state);
    let manifest = member_manifest(workspace, workspace_root, popped.0);
    register_workspace_package(state, package_name(manifest), package_version_in_workspace(manifest, workspace), popped.0)
}

fn register_workspace_package(state: WorkspaceIndexState, name: String, version: String, member_path: String) -> WorkspaceIndexState {
    match state.package_ids.get(name) {
        Some(_) => state,
        None => register_workspace_package_new(state, name, version, member_path),
    }
}

fn register_workspace_package_new(state: WorkspaceIndexState, name: String, version: String, member_path: String) -> WorkspaceIndexState {
    let pkg = state.next_pkg;
    let version_id = state.next_version;
    WorkspaceIndexState {
        packages: state.packages.push(pkg),
        package_ids: state.package_ids.insert(name, pkg),
        member_paths: state.member_paths.insert(pkg, member_path),
        names: state.names.insert(pkg, name),
        version_ids: state.version_ids.push(version_id),
        version_pkgs: state.version_pkgs.insert(version_id, pkg),
        version_values: state.version_values.insert(version_id, version),
        next_pkg: pkg + 1,
        next_version: version_id + 1,
        ..state
    }
}

fn register_sparse_package_name(state: WorkspaceIndexState, name: String) -> WorkspaceIndexState {
    match state.package_ids.get(name) {
        Some(_) => state,
        None => register_sparse_package_name_new(state, name),
    }
}

fn register_sparse_package_name_new(state: WorkspaceIndexState, name: String) -> WorkspaceIndexState {
    let pkg = state.next_pkg;
    WorkspaceIndexState {
        packages: state.packages.push(pkg),
        package_ids: state.package_ids.insert(name, pkg),
        member_paths: state.member_paths.insert(pkg, ""),
        names: state.names.insert(pkg, name),
        next_pkg: pkg + 1,
        ..state
    }
}

fn register_sparse_version(state: WorkspaceIndexState, pkg: Int, version: String) -> WorkspaceIndexState {
    let version_id = state.next_version;
    WorkspaceIndexState {
        version_ids: state.version_ids.push(version_id),
        version_pkgs: state.version_pkgs.insert(version_id, pkg),
        version_values: state.version_values.insert(version_id, version),
        next_version: version_id + 1,
        ..state
    }
}

fn register_sparse_rows(rows: [SparseIndexRow], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match rows.len() == 0 {
        true => state,
        false => register_sparse_rows_tuple(rows.pop(), state),
    }
}

fn register_sparse_rows_tuple(popped: (SparseIndexRow, [SparseIndexRow]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    register_sparse_row(register_sparse_rows(popped.1, state), popped.0)
}

fn register_sparse_row(state: WorkspaceIndexState, row: SparseIndexRow) -> WorkspaceIndexState {
    let name = sparse_row_name(row);
    match state.package_ids.get(name) {
        Some(pkg) => register_sparse_existing_row(state, pkg, row),
        None => register_sparse_new_row(state, name, row),
    }
}

fn register_sparse_existing_row(state: WorkspaceIndexState, pkg: Int, row: SparseIndexRow) -> WorkspaceIndexState {
    register_sparse_row_with_pkg(state, pkg, row)
}

fn register_sparse_new_row(state: WorkspaceIndexState, name: String, row: SparseIndexRow) -> WorkspaceIndexState {
    let pkg = state.next_pkg;
    let state = register_sparse_package_name_new(state, name);
    register_sparse_row_with_pkg(state, pkg, row)
}

fn register_sparse_row_with_pkg(state: WorkspaceIndexState, pkg: Int, row: SparseIndexRow) -> WorkspaceIndexState {
    match sparse_row_yanked(row) {
        true => state,
        false => register_sparse_version(state, pkg, sparse_row_vers(row)),
    }
}

fn register_feature(state: WorkspaceIndexState, pkg: Int, feature: String) -> WorkspaceIndexState {
    let key = feature_key(state, pkg, feature);
    match state.feature_keys.get(key) {
        Some(_) => state,
        None => register_new_feature(state, pkg, feature, key),
    }
}

fn register_new_feature(state: WorkspaceIndexState, pkg: Int, feature: String, key: String) -> WorkspaceIndexState {
    let id = state.next_feature;
    WorkspaceIndexState {
        feature_ids: state.feature_ids.push(id),
        feature_keys: state.feature_keys.insert(key, id),
        feature_pkgs: state.feature_pkgs.insert(id, pkg),
        feature_names: state.feature_names.insert(id, feature),
        feature_enables: state.feature_enables.insert(id, ""),
        next_feature: id + 1,
        ..state
    }
}

fn feature_key(state: WorkspaceIndexState, pkg: Int, feature: String) -> String {
    state.names.get(pkg).unwrap() + "\t" + feature
}

fn feature_id(state: WorkspaceIndexState, pkg: Int, feature: String) -> Int {
    state.feature_keys.get(feature_key(state, pkg, feature)).unwrap()
}

fn feature_id_opt(state: WorkspaceIndexState, pkg: Int, feature: String) -> Option<Int> {
    state.feature_keys.get(feature_key(state, pkg, feature))
}

fn register_sparse_features(pkg: Int, row: SparseIndexRow, state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_sparse_feature_names(pkg, sparse_row_feature_names(row), state);
    let state = register_sparse_dep_features(pkg, sparse_row_deps(row), state);
    let state = register_sparse_feature_enables(pkg, row, sparse_row_feature_names(row), state);
    register_sparse_feature_targets(pkg, sparse_row_deps(row), state)
}

fn register_sparse_feature_names(pkg: Int, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => register_sparse_feature_names_tuple(pkg, features.pop(), state),
    }
}

fn register_sparse_feature_names_tuple(pkg: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    register_sparse_feature_names(pkg, popped.1, register_feature(state, pkg, popped.0))
}

fn register_sparse_dep_features(pkg: Int, deps: [SparseIndexDep], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match deps.len() == 0 {
        true => state,
        false => register_sparse_dep_features_tuple(pkg, deps.pop(), state),
    }
}

fn register_sparse_dep_features_tuple(pkg: Int, popped: (SparseIndexDep, [SparseIndexDep]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let dep = popped.0;
    let state = match dep.optional {
        true => register_feature(state, pkg, sparse_dep_package_name(dep)),
        false => state,
    };
    register_sparse_dep_features(pkg, popped.1, state)
}

fn register_sparse_feature_enables(pkg: Int, row: SparseIndexRow, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => register_sparse_feature_enables_tuple(pkg, row, features.pop(), state),
    }
}

fn register_sparse_feature_enables_tuple(pkg: Int, row: SparseIndexRow, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_sparse_feature_enables(pkg, row, popped.1, state);
    register_feature_enables(state, pkg, popped.0, sparse_feature_enables(row, popped.0))
}

fn register_sparse_feature_targets(pkg: Int, deps: [SparseIndexDep], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match deps.len() == 0 {
        true => state,
        false => register_sparse_feature_targets_tuple(pkg, deps.pop(), state),
    }
}

fn register_sparse_feature_targets_tuple(pkg: Int, popped: (SparseIndexDep, [SparseIndexDep]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_sparse_feature_targets(pkg, popped.1, state);
    let dep = popped.0;
    match dep.optional {
        true => register_feature_target(state, pkg, sparse_dep_package_name(dep), sparse_dep_target(dep)),
        false => state,
    }
}

fn add_workspace_root_member_clauses(state: WorkspaceIndexState, member_pkg_ids: [Int]) -> WorkspaceIndexState {
    match member_pkg_ids.len() == 0 {
        true => state,
        false => add_workspace_root_member_clauses_tuple(state, member_pkg_ids.pop()),
    }
}

fn add_workspace_root_member_clauses_tuple(state: WorkspaceIndexState, popped: (Int, [Int])) -> WorkspaceIndexState {
    add_workspace_root_member_clauses(add_workspace_root_member_clause(state, popped.0), popped.1)
}

fn add_workspace_root_member_clause(state: WorkspaceIndexState, member_pkg: Int) -> WorkspaceIndexState {
    let member_req = "=" + workspace_state_version_text(state, member_pkg);
    let state = workspace_add_selected_guard_clause(
        workspace_add_selected_guard_clause(state, 0, "0.0.0", "in_graph", member_pkg, VersionSet::from_req("*"), "*", "normal"),
        0,
        "0.0.0",
        "version_set",
        member_pkg,
        VersionSet::from_req(member_req),
        member_req,
        "normal",
    );
    match feature_id_opt(state, member_pkg, "default") {
        Some(default_feature) => workspace_add_selected_feature_clause(state, 0, "0.0.0", member_pkg, default_feature, "normal"),
        None => state,
    }
}

fn add_workspace_required_dep_clauses(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_pkg: Int, req: String, kind: String) -> WorkspaceIndexState {
    add_workspace_required_dep_clauses_target(state, parent_pkg, parent_version, dep_pkg, req, kind, None)
}

fn add_workspace_required_dep_clauses_target(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_pkg: Int, req: String, kind: String, target: Option<String>) -> WorkspaceIndexState {
    workspace_add_selected_guard_clause_target(
        workspace_add_selected_guard_clause_target(state, parent_pkg, parent_version, "in_graph", dep_pkg, VersionSet::from_req("*"), "*", kind, target),
        parent_pkg,
        parent_version,
        "version_set",
        dep_pkg,
        VersionSet::from_req(req),
        req,
        kind,
        target,
    )
}

fn workspace_member_pkg_ids(state: WorkspaceIndexState, members: [String], out: [Int]) -> [Int] {
    match members.len() == 0 {
        true => out,
        false => workspace_member_pkg_ids_tuple(state, members.pop(), out),
    }
}

fn workspace_member_pkg_ids_tuple(state: WorkspaceIndexState, popped: (String, [String]), out: [Int]) -> [Int] {
    let out = workspace_member_pkg_ids(state, popped.1, out);
    let name = workspace_member_package_name(state, popped.0, state.packages);
    out.push(state.package_ids.get(name).unwrap())
}

fn workspace_member_package_name(state: WorkspaceIndexState, member: String, packages: [Int]) -> String {
    match packages.len() == 0 {
        true => "",
        false => workspace_member_package_name_tuple(state, member, packages.pop()),
    }
}

fn workspace_member_package_name_tuple(state: WorkspaceIndexState, member: String, popped: (Int, [Int])) -> String {
    match state.member_paths.get(popped.0) {
        Some(path) => match path == member {
            true => state.names.get(popped.0).unwrap(),
            false => workspace_member_package_name(state, member, popped.1),
        },
        None => workspace_member_package_name(state, member, popped.1),
    }
}

fn workspace_add_selected_guard_clause(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, consequent_tag: String, dep_pkg: Int, req: VersionSet, req_text: String, kind: String) -> WorkspaceIndexState {
    workspace_add_selected_guard_clause_target(state, parent_pkg, parent_version, consequent_tag, dep_pkg, req, req_text, kind, None)
}

fn workspace_add_selected_guard_clause_target(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, consequent_tag: String, dep_pkg: Int, req: VersionSet, req_text: String, kind: String, target: Option<String>) -> WorkspaceIndexState {
    let clause_id = state.next_clause;
    let guard_id = state.next_guard;
    WorkspaceIndexState {
        clause_ids: state.clause_ids.push(clause_id),
        guard_ids: state.guard_ids.push(guard_id),
        guard_clause_ids: state.guard_clause_ids.insert(guard_id, clause_id),
        guard_tags: state.guard_tags.insert(guard_id, "selected"),
        guard_kinds: state.guard_kinds.insert(guard_id, 0),
        guard_pkgs: state.guard_pkgs.insert(guard_id, parent_pkg),
        guard_version_values: state.guard_version_values.insert(guard_id, parent_version),
        guard_features: state.guard_features.insert(guard_id, 0),
        consequent_tags: state.consequent_tags.insert(clause_id, consequent_tag),
        consequent_pkgs: state.consequent_pkgs.insert(clause_id, dep_pkg),
        consequent_version_sets: state.consequent_version_sets.insert(clause_id, req),
        consequent_req_texts: state.consequent_req_texts.insert(clause_id, req_text),
        consequent_features: state.consequent_features.insert(clause_id, 0),
        gate_kinds: state.gate_kinds.insert(clause_id, kind),
        gate_targets: workspace_gate_targets_insert(state.gate_targets, clause_id, target),
        next_clause: clause_id + 1,
        next_guard: guard_id + 1,
        ..state
    }
}

fn workspace_add_selected_feature_clause(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, feature_pkg: Int, feature: Int, kind: String) -> WorkspaceIndexState {
    workspace_add_selected_feature_clause_target(state, parent_pkg, parent_version, feature_pkg, feature, kind, None)
}

fn workspace_add_selected_feature_clause_target(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, feature_pkg: Int, feature: Int, kind: String, target: Option<String>) -> WorkspaceIndexState {
    let clause_id = state.next_clause;
    let guard_id = state.next_guard;
    WorkspaceIndexState {
        clause_ids: state.clause_ids.push(clause_id),
        guard_ids: state.guard_ids.push(guard_id),
        guard_clause_ids: state.guard_clause_ids.insert(guard_id, clause_id),
        guard_tags: state.guard_tags.insert(guard_id, "selected"),
        guard_kinds: state.guard_kinds.insert(guard_id, 0),
        guard_pkgs: state.guard_pkgs.insert(guard_id, parent_pkg),
        guard_version_values: state.guard_version_values.insert(guard_id, parent_version),
        guard_features: state.guard_features.insert(guard_id, 0),
        consequent_tags: state.consequent_tags.insert(clause_id, "feature"),
        consequent_pkgs: state.consequent_pkgs.insert(clause_id, feature_pkg),
        consequent_version_sets: state.consequent_version_sets.insert(clause_id, VersionSet::from_req("*")),
        consequent_req_texts: state.consequent_req_texts.insert(clause_id, "*"),
        consequent_features: state.consequent_features.insert(clause_id, feature),
        gate_kinds: state.gate_kinds.insert(clause_id, kind),
        gate_targets: workspace_gate_targets_insert(state.gate_targets, clause_id, target),
        next_clause: clause_id + 1,
        next_guard: guard_id + 1,
        ..state
    }
}

fn workspace_add_feature_expansion_clause(state: WorkspaceIndexState, pkg: Int, version: String, guard_feature: Int, feature_pkg: Int, feature: Int) -> WorkspaceIndexState {
    workspace_add_feature_expansion_clause_target(state, pkg, version, guard_feature, feature_pkg, feature, "normal", None)
}

fn workspace_add_feature_expansion_clause_target(state: WorkspaceIndexState, pkg: Int, version: String, guard_feature: Int, feature_pkg: Int, feature: Int, kind: String, target: Option<String>) -> WorkspaceIndexState {
    let clause_id = state.next_clause;
    let selected_guard = state.next_guard;
    let feature_guard = selected_guard + 1;
    WorkspaceIndexState {
        clause_ids: state.clause_ids.push(clause_id),
        guard_ids: state.guard_ids.push(selected_guard).push(feature_guard),
        guard_clause_ids: state.guard_clause_ids.insert(selected_guard, clause_id).insert(feature_guard, clause_id),
        guard_tags: state.guard_tags.insert(selected_guard, "selected").insert(feature_guard, "feature"),
        guard_kinds: state.guard_kinds.insert(selected_guard, 0).insert(feature_guard, 2),
        guard_pkgs: state.guard_pkgs.insert(selected_guard, pkg).insert(feature_guard, pkg),
        guard_version_values: state.guard_version_values.insert(selected_guard, version),
        guard_features: state.guard_features.insert(selected_guard, 0).insert(feature_guard, guard_feature),
        consequent_tags: state.consequent_tags.insert(clause_id, "feature"),
        consequent_pkgs: state.consequent_pkgs.insert(clause_id, feature_pkg),
        consequent_version_sets: state.consequent_version_sets.insert(clause_id, VersionSet::from_req("*")),
        consequent_req_texts: state.consequent_req_texts.insert(clause_id, "*"),
        consequent_features: state.consequent_features.insert(clause_id, feature),
        gate_kinds: state.gate_kinds.insert(clause_id, kind),
        gate_targets: workspace_gate_targets_insert(state.gate_targets, clause_id, target),
        next_clause: clause_id + 1,
        next_guard: feature_guard + 1,
        ..state
    }
}

fn workspace_gate_targets_insert(gate_targets: Map<Int, String>, clause_id: Int, target: Option<String>) -> Map<Int, String> {
    match target {
        Some(expr) => gate_targets.insert(clause_id, expr),
        None => gate_targets,
    }
}

fn workspace_index_state(workspace: Tree, workspace_root: Path) -> WorkspaceIndexState {
    let members = workspace_members(workspace);
    workspace_index_state_for_members(workspace, workspace_root, members)
}

fn workspace_index_state_limit(workspace: Tree, workspace_root: Path, limit: Int) -> WorkspaceIndexState {
    workspace_index_state_for_members(workspace, workspace_root, take_strings(workspace_members(workspace), limit, []))
}

fn workspace_index_state_for_members(workspace: Tree, workspace_root: Path, members: [String]) -> WorkspaceIndexState {
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    register_workspace_direct_deps(workspace, workspace_root, members, state)
}

fn workspace_index_state_with_sparse_rows_limit(workspace: Tree, workspace_root: Path, sparse_jsonl: String, limit: Int) -> WorkspaceIndexState {
    let members = take_strings(workspace_members(workspace), limit, []);
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    let state = register_sparse_rows(rows, state);
    register_workspace_direct_deps(workspace, workspace_root, members, state)
}

fn workspace_index_state_with_transitive_sparse_rows_limit(workspace: Tree, workspace_root: Path, sparse_jsonl: String, limit: Int) -> WorkspaceIndexState {
    let members = take_strings(workspace_members(workspace), limit, []);
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    let state = register_sparse_rows(rows, state);
    let state = register_workspace_direct_deps(workspace, workspace_root, members, state);
    add_sparse_dependency_clauses(rows, state)
}

pub fn workspace_index_state_with_transitive_sparse_rows_for_members(workspace: Tree, workspace_root: Path, sparse_jsonl: String, members: [String]) -> WorkspaceIndexState {
    let rows = parse_sparse_jsonl(sparse_jsonl);
    let state = workspace_member_only_index_state_for_members(workspace, workspace_root, members);
    let state = register_sparse_rows(rows, state);
    let state = register_workspace_direct_deps(workspace, workspace_root, members, state);
    add_sparse_dependency_clauses(rows, state)
}

fn add_sparse_dependency_clauses(rows: [SparseIndexRow], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match rows.len() == 0 {
        true => state,
        false => add_sparse_dependency_clauses_tuple(rows.pop(), state),
    }
}

fn add_sparse_dependency_clauses_tuple(popped: (SparseIndexRow, [SparseIndexRow]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    add_sparse_dependency_clauses(popped.1, add_sparse_row_dependency_clauses(popped.0, state))
}

fn add_sparse_row_dependency_clauses(row: SparseIndexRow, state: WorkspaceIndexState) -> WorkspaceIndexState {
    match sparse_row_yanked(row) {
        true => state,
        false => match state.package_ids.get(sparse_row_name(row)) {
            Some(parent_pkg) => add_sparse_deps_for_row(parent_pkg, sparse_row_vers(row), sparse_row_deps(row), state),
            None => state,
        },
    }
}

fn add_sparse_deps_for_row(parent_pkg: Int, parent_version: String, deps: [SparseIndexDep], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match deps.len() == 0 {
        true => state,
        false => add_sparse_deps_for_row_tuple(parent_pkg, parent_version, deps.pop(), state),
    }
}

fn add_sparse_deps_for_row_tuple(parent_pkg: Int, parent_version: String, popped: (SparseIndexDep, [SparseIndexDep]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    add_sparse_deps_for_row(parent_pkg, parent_version, popped.1, add_sparse_dep_clause(parent_pkg, parent_version, popped.0, state))
}

fn add_sparse_dep_clause(parent_pkg: Int, parent_version: String, dep: SparseIndexDep, state: WorkspaceIndexState) -> WorkspaceIndexState {
    match sparse_dep_consumed(dep) {
        false => state,
        true => match state.package_ids.get(sparse_dep_package_name(dep)) {
            Some(dep_pkg) => add_sparse_dep_clause_for_pkg(parent_pkg, parent_version, dep, state, dep_pkg),
            None => state,
        },
    }
}

fn add_sparse_dep_clause_for_pkg(parent_pkg: Int, parent_version: String, dep: SparseIndexDep, state: WorkspaceIndexState, dep_pkg: Int) -> WorkspaceIndexState {
    let state = add_workspace_required_dep_clauses_target(state, parent_pkg, parent_version, dep_pkg, sparse_dep_req(dep), sparse_dep_kind(dep), sparse_dep_target(dep));
    add_dependency_requested_feature_clauses(state, parent_pkg, parent_version, dep_pkg, sparse_dep_requested_features(dep), sparse_dep_kind(dep), sparse_dep_target(dep))
}

fn sparse_dep_consumed(dep: SparseIndexDep) -> Bool {
    match dep.optional {
        true => false,
        false => match dep.kind == "dev" {
            true => false,
            false => true,
        },
    }
}

fn sparse_dep_package_name(dep: SparseIndexDep) -> String {
    match dep.package == "" {
        true => dep.name,
        false => dep.package,
    }
}

fn sparse_dep_req(dep: SparseIndexDep) -> String {
    dep.req
}

fn sparse_dep_kind(dep: SparseIndexDep) -> String {
    dep.kind
}

fn sparse_dep_target(dep: SparseIndexDep) -> Option<String> {
    match dep.target == "" {
        true => None,
        false => Some(dep.target),
    }
}

fn sparse_dep_requested_features(dep: SparseIndexDep) -> [String] {
    match dep.default_features {
        true => dep.features.push("default"),
        false => dep.features,
    }
}

fn add_dependency_requested_feature_clauses(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_pkg: Int, features: [String], kind: String, target: Option<String>) -> WorkspaceIndexState {
    let state = match state.member_paths.get(dep_pkg).unwrap() == "" {
        true => register_feature_names(dep_pkg, features, state),
        false => state,
    };
    add_dependency_requested_feature_clauses_registered(state, parent_pkg, parent_version, dep_pkg, features, kind, target)
}

fn add_dependency_requested_feature_clauses_registered(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_pkg: Int, features: [String], kind: String, target: Option<String>) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => add_dependency_requested_feature_clauses_tuple(state, parent_pkg, parent_version, dep_pkg, features.pop(), kind, target),
    }
}

fn add_dependency_requested_feature_clauses_tuple(state: WorkspaceIndexState, parent_pkg: Int, parent_version: String, dep_pkg: Int, popped: (String, [String]), kind: String, target: Option<String>) -> WorkspaceIndexState {
    let state = add_dependency_requested_feature_clauses_registered(state, parent_pkg, parent_version, dep_pkg, popped.1, kind, target);
    match feature_id_opt(state, dep_pkg, popped.0) {
        Some(feature) => workspace_add_selected_feature_clause_target(state, parent_pkg, parent_version, dep_pkg, feature, kind, target),
        None => state,
    }
}

fn register_feature_names(pkg: Int, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => register_feature_names_tuple(pkg, features.pop(), state),
    }
}

fn register_feature_names_tuple(pkg: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    register_feature_names(pkg, popped.1, register_feature(state, pkg, popped.0))
}

fn add_local_feature_enables(pkg: Int, version: String, guard_feature: Int, enables: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match enables.len() == 0 {
        true => state,
        false => add_local_feature_enables_tuple(pkg, version, guard_feature, enables.pop(), state),
    }
}

fn add_local_feature_enables_tuple(pkg: Int, version: String, guard_feature: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = add_local_feature_enables(pkg, version, guard_feature, popped.1, state);
    add_local_feature_enable(pkg, version, guard_feature, popped.0, state)
}

fn add_local_feature_enable(pkg: Int, version: String, guard_feature: Int, enable: String, state: WorkspaceIndexState) -> WorkspaceIndexState {
    let local = local_feature_name_from_enable(enable);
    match local == "" {
        true => state,
        false => match feature_id_opt(state, pkg, local) {
            Some(feature) => workspace_add_feature_expansion_clause(state, pkg, version, guard_feature, pkg, feature),
            None => state,
        },
    }
}

fn local_feature_name_from_enable(enable: String) -> String {
    match enable.contains("?/") {
        true => "",
        false => match enable.contains("/") {
            true => enable.before("/"),
            false => match enable.contains("dep:") {
                true => enable.after("dep:"),
                false => enable,
            },
        },
    }
}

fn add_sparse_feature_expansion_clauses(rows: [SparseIndexRow], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match rows.len() == 0 {
        true => state,
        false => add_sparse_feature_expansion_clauses_tuple(rows.pop(), state),
    }
}

fn add_sparse_feature_expansion_clauses_tuple(popped: (SparseIndexRow, [SparseIndexRow]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    add_sparse_feature_expansion_clauses(popped.1, add_sparse_row_feature_expansion_clauses(popped.0, state))
}

fn add_sparse_row_feature_expansion_clauses(row: SparseIndexRow, state: WorkspaceIndexState) -> WorkspaceIndexState {
    match sparse_row_yanked(row) {
        true => state,
        false => match state.package_ids.get(sparse_row_name(row)) {
            Some(pkg) => add_sparse_feature_name_expansion_clauses(row, pkg, sparse_row_vers(row), sparse_row_feature_names(row), state),
            None => state,
        },
    }
}

fn add_sparse_feature_name_expansion_clauses(row: SparseIndexRow, pkg: Int, version: String, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => add_sparse_feature_name_expansion_clauses_tuple(row, pkg, version, features.pop(), state),
    }
}

fn add_sparse_feature_name_expansion_clauses_tuple(row: SparseIndexRow, pkg: Int, version: String, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = add_sparse_feature_name_expansion_clauses(row, pkg, version, popped.1, state);
    let guard_feature = feature_id(state, pkg, popped.0);
    add_sparse_feature_enables(row, pkg, version, guard_feature, sparse_feature_enables(row, popped.0), state)
}

fn add_sparse_feature_enables(row: SparseIndexRow, pkg: Int, version: String, guard_feature: Int, enables: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match enables.len() == 0 {
        true => state,
        false => add_sparse_feature_enables_tuple(row, pkg, version, guard_feature, enables.pop(), state),
    }
}

fn add_sparse_feature_enables_tuple(row: SparseIndexRow, pkg: Int, version: String, guard_feature: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = add_sparse_feature_enables(row, pkg, version, guard_feature, popped.1, state);
    add_sparse_feature_enable(row, pkg, version, guard_feature, popped.0, state)
}

fn add_sparse_feature_enable(row: SparseIndexRow, pkg: Int, version: String, guard_feature: Int, enable: String, state: WorkspaceIndexState) -> WorkspaceIndexState {
    let local = local_feature_name_from_enable(enable);
    match local == "" {
        true => state,
        false => match feature_id_opt(state, pkg, local) {
            Some(feature) => workspace_add_feature_expansion_clause_target(state, pkg, version, guard_feature, pkg, feature, "normal", sparse_feature_target(row, local)),
            None => state,
        },
    }
}

fn sparse_feature_target(row: SparseIndexRow, feature: String) -> Option<String> {
    sparse_dep_target_for_package(row.deps, feature)
}

fn sparse_dep_target_for_package(deps: [SparseIndexDep], feature: String) -> Option<String> {
    match deps.len() == 0 {
        true => None,
        false => sparse_dep_target_for_package_tuple(deps.pop(), feature),
    }
}

fn sparse_dep_target_for_package_tuple(popped: (SparseIndexDep, [SparseIndexDep]), feature: String) -> Option<String> {
    let dep = popped.0;
    let package = match dep.package == "" {
        true => dep.name,
        false => dep.package,
    };
    let target = match dep.target == "" {
        true => None,
        false => Some(dep.target),
    };
    match package == feature {
        true => match dep.optional {
            true => target,
            false => sparse_dep_target_for_package(popped.1, feature),
        },
        false => sparse_dep_target_for_package(popped.1, feature),
    }
}

fn workspace_member_only_index_state(workspace: Tree, workspace_root: Path) -> WorkspaceIndexState {
    workspace_member_only_index_state_for_members(workspace, workspace_root, workspace_members(workspace))
}

fn workspace_member_only_index_state_limit(workspace: Tree, workspace_root: Path, limit: Int) -> WorkspaceIndexState {
    workspace_member_only_index_state_for_members(workspace, workspace_root, take_strings(workspace_members(workspace), limit, []))
}

fn workspace_member_only_index_state_for_members(workspace: Tree, workspace_root: Path, members: [String]) -> WorkspaceIndexState {
    let state = register_workspace_members(workspace, workspace_root, members, register_workspace_pseudo_root(empty_workspace_index_state()));
    let state = register_workspace_member_features(workspace, workspace_root, members, state);
    add_workspace_root_member_clauses(state, workspace_member_pkg_ids(state, members, []))
}

pub fn workspace_member_only_package_count_for_members(workspace: Tree, workspace_root: Path, members: [String]) -> Int {
    workspace_member_only_index_state_for_members(workspace, workspace_root, members).packages.len()
}

pub fn workspace_member_only_package_names_text_for_members(workspace: Tree, workspace_root: Path, members: [String]) -> String {
    workspace_index_package_names_text(workspace_member_only_index_state_for_members(workspace, workspace_root, members))
}

fn register_workspace_member_features(workspace: Tree, workspace_root: Path, members: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match members.len() == 0 {
        true => state,
        false => register_workspace_member_features_tuple(workspace, workspace_root, members.pop(), state),
    }
}

fn register_workspace_member_features_tuple(workspace: Tree, workspace_root: Path, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_workspace_member_features(workspace, workspace_root, popped.1, state);
    let manifest = member_manifest(workspace, workspace_root, popped.0);
    let pkg = state.package_ids.get(package_name(manifest)).unwrap();
    let state = register_manifest_feature_names(pkg, manifest_feature_names(manifest), state);
    let state = register_manifest_feature_enables(manifest, pkg, manifest_feature_names(manifest), state);
    let state = register_manifest_optional_dep_features(manifest, pkg, dependency_names(manifest, "normal"), "normal", state);
    let state = register_manifest_optional_dep_features(manifest, pkg, dependency_names(manifest, "build"), "build", state);
    register_manifest_optional_dep_features(manifest, pkg, dependency_names(manifest, "dev"), "dev", state)
}

fn register_manifest_feature_names(pkg: Int, names: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match names.len() == 0 {
        true => state,
        false => register_manifest_feature_names_tuple(pkg, names.pop(), state),
    }
}

fn register_manifest_feature_names_tuple(pkg: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    register_manifest_feature_names(pkg, popped.1, register_feature(state, pkg, popped.0))
}

fn register_manifest_optional_dep_features(manifest: Tree, pkg: Int, names: [String], kind: String, state: WorkspaceIndexState) -> WorkspaceIndexState {
    match names.len() == 0 {
        true => state,
        false => register_manifest_optional_dep_features_tuple(manifest, pkg, names.pop(), kind, state),
    }
}

fn register_manifest_optional_dep_features_tuple(manifest: Tree, pkg: Int, popped: (String, [String]), kind: String, state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_manifest_optional_dep_features(manifest, pkg, popped.1, kind, state);
    let dep = dependency_doc(manifest, popped.0, kind);
    match dependency_optional(dep) {
        true => register_feature(state, pkg, dependency_package_name(dep, popped.0)),
        false => state,
    }
}

fn manifest_feature_names(manifest: Tree) -> [String] {
    match manifest_doc(manifest).get("features") {
        Some(features) => features.keys(),
        None => [],
    }
}

fn manifest_feature_enables(manifest: Tree, feature: String) -> [String] {
    match manifest_doc(manifest).get("features") {
        Some(features) => doc_as_strings(features.get(feature).unwrap()),
        None => [],
    }
}

fn add_workspace_feature_expansion_clauses(workspace: Tree, workspace_root: Path, members: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match members.len() == 0 {
        true => state,
        false => add_workspace_feature_expansion_clauses_tuple(workspace, workspace_root, members.pop(), state),
    }
}

fn add_workspace_feature_expansion_clauses_tuple(workspace: Tree, workspace_root: Path, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = add_workspace_feature_expansion_clauses(workspace, workspace_root, popped.1, state);
    let manifest = member_manifest(workspace, workspace_root, popped.0);
    let pkg = state.package_ids.get(package_name(manifest)).unwrap();
    add_manifest_feature_expansion_clauses(manifest, pkg, package_version_in_workspace(manifest, workspace), manifest_feature_names(manifest), state)
}

fn add_manifest_feature_expansion_clauses(manifest: Tree, pkg: Int, version: String, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => add_manifest_feature_expansion_clauses_tuple(manifest, pkg, version, features.pop(), state),
    }
}

fn add_manifest_feature_expansion_clauses_tuple(manifest: Tree, pkg: Int, version: String, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = add_manifest_feature_expansion_clauses(manifest, pkg, version, popped.1, state);
    let guard_feature = feature_id(state, pkg, popped.0);
    add_local_feature_enables(pkg, version, guard_feature, manifest_feature_enables(manifest, popped.0), state)
}

fn register_manifest_feature_enables(manifest: Tree, pkg: Int, features: [String], state: WorkspaceIndexState) -> WorkspaceIndexState {
    match features.len() == 0 {
        true => state,
        false => register_manifest_feature_enables_tuple(manifest, pkg, features.pop(), state),
    }
}

fn register_manifest_feature_enables_tuple(manifest: Tree, pkg: Int, popped: (String, [String]), state: WorkspaceIndexState) -> WorkspaceIndexState {
    let state = register_manifest_feature_enables(manifest, pkg, popped.1, state);
    register_feature_enables(state, pkg, popped.0, manifest_feature_enables(manifest, popped.0))
}

fn register_feature_enables(state: WorkspaceIndexState, pkg: Int, feature: String, enables: [String]) -> WorkspaceIndexState {
    let id = feature_id(state, pkg, feature);
    WorkspaceIndexState {
        feature_enables: state.feature_enables.insert(id, enables.join("\n")),
        ..state
    }
}

fn register_feature_target(state: WorkspaceIndexState, pkg: Int, feature: String, target: Option<String>) -> WorkspaceIndexState {
    match target {
        Some(expr) => WorkspaceIndexState {
            feature_targets: state.feature_targets.insert(feature_key(state, pkg, feature), expr),
            ..state
        },
        None => state,
    }
}

fn take_strings(values: [String], limit: Int, out: [String]) -> [String] {
    match limit == 0 {
        true => out,
        false => match values.len() == 0 {
            true => out,
            false => take_strings_tuple(values.pop(), limit, out),
        },
    }
}

fn take_strings_tuple(popped: (String, [String]), limit: Int, out: [String]) -> [String] {
    take_strings(popped.1, limit - 1, out.push(popped.0))
}

pub fn workspace_index_from_state(state: WorkspaceIndexState) -> Index {
    Index {
        packages: state.packages,
        names: state.names,
        version_ids: state.version_ids,
        version_pkgs: state.version_pkgs,
        version_values: state.version_values,
        clause_ids: state.clause_ids,
        guard_ids: state.guard_ids,
        guard_clause_ids: state.guard_clause_ids,
        guard_tags: state.guard_tags,
        guard_kinds: state.guard_kinds,
        guard_pkgs: state.guard_pkgs,
        guard_version_values: state.guard_version_values,
        guard_features: state.guard_features,
        consequent_tags: state.consequent_tags,
        consequent_pkgs: state.consequent_pkgs,
        consequent_version_sets: state.consequent_version_sets,
        consequent_features: state.consequent_features,
        gate_kinds: state.gate_kinds,
        gate_targets: state.gate_targets,
    }
}

fn workspace_problem() -> Problem {
    Problem {
        root_pkg: 0,
        root_req: VersionSet::from_req("*"),
        root_features: [],
        root_default_feature: 0,
        root_default_features: false,
    }
}

