// eval.vix — the self-hosting shape: what an intelligence query looks like.
//
// resolve/type_of will be programs of exactly this kind, run by the demand
// engine, memoized because they cannot help but be. Recursive enums need no
// Box (values, not places); maps are persistent values (insert returns anew).

use vix::Map;

enum Expr {
    Num(Float),
    Var(String),
    Add(Expr, Expr),
    Mul(Expr, Expr),
    Let { name: String, value: Expr, body: Expr },
}

fn eval(e: Expr, env: Map<String, Float>) -> Float {
    match e {
        Expr::Num(n) => n,
        Expr::Var(name) => env.get(name).unwrap(),
        Expr::Add(a, b) => eval(a, env) + eval(b, env),
        Expr::Mul(a, b) => eval(a, env) * eval(b, env),
        Expr::Let { name, value, body } =>
            eval(body, env.insert(name, eval(value, env))),
    }
}

pub fn demo() -> Float {
    let program = Expr::Let {
        name: "x",
        value: Expr::Num(6.0),
        body: Expr::Mul(Expr::Var("x"), Expr::Num(7.0)),
    };
    eval(program, Map::new())
}
