use vix::{Tree, Target, Path, Os, Map, Version, VersionSet, Arg};
use caps::Rustc;
use rodin::{Index, Problem, SolveResult, gate_active_id, solve};

fn doc_string(doc: Doc, key: String) -> String {
    doc.get(key).unwrap()
}

fn doc_as_string(doc: Doc) -> String {
    doc
}

fn doc_as_bool(doc: Doc) -> Bool {
    doc
}

fn doc_as_strings(doc: Doc) -> [String] {
    doc
}

fn crate_name(package_name: String) -> String {
    match package_name.contains("-") {
        true => crate_name(package_name.before("-") + "_" + package_name.after("-")),
        false => package_name,
    }
}

fn package_doc(manifest: Tree) -> Doc {
    let doc = toml(manifest / p"Cargo.toml");
    doc.get("package").unwrap()
}

fn workspace_package_doc(source: Tree) -> Doc {
    toml(source / p"Cargo.toml").get("workspace").unwrap().get("package").unwrap()
}

pub fn package_edition_from_source(source: Tree, manifest: Tree) -> String {
    match package_doc(manifest).get("edition") {
        Some(edition) => match edition.is_map() {
            true => doc_string(workspace_package_doc(source), "edition"),
            false => doc_as_string(edition),
        },
        None => "2015",
    }
}

fn lock_doc(graph: Tree) -> Doc {
    toml(graph / p"Cargo.lock")
}

fn lock_package(lock: Doc, name: String) -> Doc {
    lock.package(name).unwrap()
}

fn lock_package_name(lock: Doc, name: String) -> String {
    let package = lock_package(lock, name);
    doc_string(package, "name")
}

fn lock_package_version(lock: Doc, name: String) -> String {
    let package = lock_package(lock, name);
    doc_string(package, "version")
}

pub fn lock_fixture_deps(graph: Tree, name: String) -> String {
    let lock = lock_doc(graph);
    let package = lock_package(lock, name);
    package.get("dependencies").unwrap().join(",")
}

pub fn crate_lib(target: Target, manifest: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={p"libmini_vendored.rmeta"},link={p"libmini_vendored.rlib"}
        -L dependency={manifest}
        {manifest / p"src/lib.rs"}
    }
}

fn dep_metadata(target: Target, dep: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(dep);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={p"libhelper.rmeta"},link={p"libhelper.rlib"}
        {dep / p"src/lib.rs"}
    } / p"libhelper.rmeta"
}

fn dep_rlib(target: Target, dep: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(dep);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={p"libhelper.rmeta"},link={p"libhelper.rlib"}
        {dep / p"src/lib.rs"}
    } / p"libhelper.rlib"
}

fn bin_check(target: Target, manifest: Tree, dep_meta: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type bin
        --emit=metadata={p"mini_app.rmeta"}
        --extern helper={dep_meta / p"libhelper.rmeta"}
        -L dependency={dep_meta}
        {manifest / p"src/main.rs"}
    }
}

fn bin_link(target: Target, manifest: Tree, dep_rlib: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type bin
        --emit=link={p"mini_app"}
        --extern helper={dep_rlib / p"libhelper.rlib"}
        -L dependency={dep_rlib}
        {manifest / p"src/main.rs"}
    }
}

pub fn crate_bin_check(target: Target, graph: Tree) -> Tree {
    let dep = graph / p"crates/helper";
    let root = graph / p"app";
    let meta = dep_metadata(target, dep);
    bin_check(target, root, meta) / p"mini_app.rmeta"
}

pub fn crate_bin(target: Target, graph: Tree) -> Tree {
    let dep = graph / p"crates/helper";
    let root = graph / p"app";
    let rlib = dep_rlib(target, dep);
    bin_link(target, root, rlib) / p"mini_app"
}

fn lock_lib_metadata(target: Target, manifest: Tree, package: Doc, rmeta: Path, rlib: Path) -> Tree {
    let rustc = Rustc::acquire(target);
    let name = doc_string(package, "name");
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={rmeta},link={rlib}
        {manifest / p"src/lib.rs"}
    }
}

fn lock_core_meta(target: Target, graph: Tree, lock: Doc) -> Tree {
    let package = lock_package(lock, "core_lib");
    lock_lib_metadata(target, graph / p"crates/core_lib", package, p"libcore_lib.rmeta", p"libcore_lib.rlib") / p"libcore_lib.rmeta"
}

fn lock_core_rlib(target: Target, graph: Tree, lock: Doc) -> Tree {
    let package = lock_package(lock, "core_lib");
    lock_lib_metadata(target, graph / p"crates/core_lib", package, p"libcore_lib.rmeta", p"libcore_lib.rlib") / p"libcore_lib.rlib"
}

fn lock_formatting_meta(target: Target, graph: Tree, lock: Doc) -> Tree {
    let package = lock_package(lock, "formatting_lib");
    lock_lib_metadata(target, graph / p"crates/formatting_lib", package, p"libformatting_lib.rmeta", p"libformatting_lib.rlib") / p"libformatting_lib.rmeta"
}

fn lock_formatting_rlib(target: Target, graph: Tree, lock: Doc) -> Tree {
    let package = lock_package(lock, "formatting_lib");
    lock_lib_metadata(target, graph / p"crates/formatting_lib", package, p"libformatting_lib.rmeta", p"libformatting_lib.rlib") / p"libformatting_lib.rlib"
}

fn lock_alpha_metadata(target: Target, graph: Tree, lock: Doc, core: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = graph / p"crates/alpha_lib";
    let package = lock_package(lock, "alpha_lib");
    let name = doc_string(package, "name");
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={p"libalpha_lib.rmeta"},link={p"libalpha_lib.rlib"}
        --extern core_lib={core / p"libcore_lib.rmeta"}
        -L dependency={core}
        {manifest / p"src/lib.rs"}
    } / p"libalpha_lib.rmeta"
}

fn lock_alpha_rlib(target: Target, graph: Tree, lock: Doc, core: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = graph / p"crates/alpha_lib";
    let package = lock_package(lock, "alpha_lib");
    let name = doc_string(package, "name");
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        --emit=metadata={p"libalpha_lib.rmeta"},link={p"libalpha_lib.rlib"}
        --extern core_lib={core / p"libcore_lib.rlib"}
        -L dependency={core}
        {manifest / p"src/lib.rs"}
    } / p"libalpha_lib.rlib"
}

fn lock_bin_metadata(target: Target, graph: Tree, lock: Doc, alpha: Tree, formatting: Tree, core: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = graph / p"app";
    let name = lock_package_name(lock, "mini_app");
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type bin
        --emit=metadata={p"mini_app.rmeta"}
        --extern alpha_lib={alpha / p"libalpha_lib.rmeta"}
        --extern formatting_lib={formatting / p"libformatting_lib.rmeta"}
        -L dependency={alpha}
        -L dependency={formatting}
        -L dependency={core}
        {manifest / p"src/main.rs"}
    }
}

fn lock_bin_link(target: Target, graph: Tree, lock: Doc, alpha: Tree, formatting: Tree, core: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = graph / p"app";
    let name = lock_package_name(lock, "mini_app");
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type bin
        --emit=link={p"mini_app"}
        --extern alpha_lib={alpha / p"libalpha_lib.rlib"}
        --extern formatting_lib={formatting / p"libformatting_lib.rlib"}
        -L dependency={alpha}
        -L dependency={formatting}
        -L dependency={core}
        {manifest / p"src/main.rs"}
    }
}

pub fn crate_lock_bin_check(target: Target, graph: Tree) -> Tree {
    let lock = lock_doc(graph);
    let core = lock_core_meta(target, graph, lock);
    let alpha = lock_alpha_metadata(target, graph, lock, core);
    let formatting = lock_formatting_meta(target, graph, lock);
    lock_bin_metadata(target, graph, lock, alpha, formatting, core) / p"mini_app.rmeta"
}

pub fn crate_lock_bin(target: Target, graph: Tree) -> Tree {
    let lock = lock_doc(graph);
    let core = lock_core_rlib(target, graph, lock);
    let alpha = lock_alpha_rlib(target, graph, lock, core);
    let formatting = lock_formatting_rlib(target, graph, lock);
    lock_bin_link(target, graph, lock, alpha, formatting, core) / p"mini_app"
}

pub fn crate_lock_root_version(graph: Tree) -> String {
    let lock = lock_doc(graph);
    lock_package_version(lock, "mini_app")
}

struct ResolvedUnit {
    name: String,
    kind: String,
    manifest: Path,
    source: Path,
    deps: [Int],
    cfgs: [String],
    metadata: Path,
    link: Path,
    metadata_file: String,
    link_file: String,
    profile: CargoResolvedProfile,
}

struct ResolvedGraph {
    root: Int,
    units: Map<Int, ResolvedUnit>,
}

struct UnitTarget {
    kind: String,
    manifest: Path,
    source: Path,
    cfgs: [String],
    metadata: Path,
    link: Path,
    metadata_file: String,
    link_file: String,
}

struct UnitTargetTable {
    root: Int,
    targets: Map<Int, UnitTarget>,
}

struct UnitArtifactRef {
    producer: Int,
    extern_name: String,
    subpath: Path,
    compat_file: String,
}

struct CargoProfileSpec {
    opt_level: String,
    debuginfo: String,
    debug_assertions: String,
    overflow_checks: String,
    panic: String,
    lto: String,
    codegen_units: String,
    strip: String,
}

struct CargoProfileData {
    dev: CargoProfileSpec,
    release: CargoProfileSpec,
    dev_build_override: CargoProfileSpec,
    release_build_override: CargoProfileSpec,
    dev_package: CargoProfileSpec,
    release_package: CargoProfileSpec,
}

pub struct CargoResolvedProfile {
    name: String,
    opt_level: String,
    debuginfo: String,
    debug_assertions: String,
    overflow_checks: String,
    panic: String,
    lto: String,
    codegen_units: String,
    strip: String,
}

pub enum CargoUnitKind {
    Lib,
    Bin,
    ProcMacro,
    BuildScript,
    BuildDependency,
}

pub struct RustExtern {
    name: String,
    tree: Tree,
    subpath: Path,
}

pub struct RustToolchainSpec {
    name: String,
}

pub struct RustUnit {
    crate_name: String,
    crate_type: CargoUnitKind,
    toolchain: RustToolchainSpec,
    edition: String,
    manifest: Tree,
    source: Path,
    target: Target,
    emit_metadata: Option<Path>,
    emit_link: Option<Path>,
    deps_trees: [Tree],
    externs: [RustExtern],
    cfgs: [String],
    env: [Arg],
    profile: Option<CargoResolvedProfile>,
}

pub fn default_rust_toolchain() -> RustToolchainSpec {
    RustToolchainSpec { name: "rustc" }
}

fn bool_string(value: Bool) -> String {
    match value {
        true => "true",
        false => "false",
    }
}

fn int_string(value: Int) -> String {
    match value {
        0 => "0",
        1 => "1",
        2 => "2",
        3 => "3",
        4 => "4",
        16 => "16",
        256 => "256",
        _ => "0",
    }
}

fn empty_profile_spec() -> CargoProfileSpec {
    CargoProfileSpec {
        opt_level: "",
        debuginfo: "",
        debug_assertions: "",
        overflow_checks: "",
        panic: "",
        lto: "",
        codegen_units: "",
        strip: "",
    }
}

fn profile_string_field(profile: Doc, key: String) -> String {
    match profile.get(key) {
        Some(value) => doc_as_string(value),
        None => "",
    }
}

fn profile_int_field(profile: Doc, key: String) -> String {
    match profile.get(key) {
        Some(value) => int_string(value),
        None => "",
    }
}

fn profile_bool_field(profile: Doc, key: String) -> String {
    match profile.get(key) {
        Some(value) => bool_string(value),
        None => "",
    }
}

fn profile_spec_from_doc(profile: Doc) -> CargoProfileSpec {
    CargoProfileSpec {
        opt_level: profile_int_field(profile, "opt-level"),
        debuginfo: profile_int_field(profile, "debug"),
        debug_assertions: profile_bool_field(profile, "debug-assertions"),
        overflow_checks: profile_bool_field(profile, "overflow-checks"),
        panic: profile_string_field(profile, "panic"),
        lto: profile_string_field(profile, "lto"),
        codegen_units: profile_int_field(profile, "codegen-units"),
        strip: profile_string_field(profile, "strip"),
    }
}

fn profile_spec_from_root(source: Tree, name: String) -> CargoProfileSpec {
    match toml(source / p"Cargo.toml").get("profile") {
        Some(profiles) => match profiles.get(name) {
            Some(profile) => profile_spec_from_doc(profile),
            None => empty_profile_spec(),
        },
        None => empty_profile_spec(),
    }
}

fn profile_build_override_spec_from_root(source: Tree, name: String) -> CargoProfileSpec {
    match toml(source / p"Cargo.toml").get("profile") {
        Some(profiles) => match profiles.get(name) {
            Some(profile) => match profile.get("build-override") {
                Some(build_override) => profile_spec_from_doc(build_override),
                None => empty_profile_spec(),
            },
            None => empty_profile_spec(),
        },
        None => empty_profile_spec(),
    }
}

fn profile_package_spec_from_root(source: Tree, name: String, package: String) -> CargoProfileSpec {
    match toml(source / p"Cargo.toml").get("profile") {
        Some(profiles) => match profiles.get(name) {
            Some(profile) => match profile.get("package") {
                Some(packages) => match packages.get(package) {
                    Some(package_profile) => profile_spec_from_doc(package_profile),
                    None => empty_profile_spec(),
                },
                None => empty_profile_spec(),
            },
            None => empty_profile_spec(),
        },
        None => empty_profile_spec(),
    }
}

fn cargo_profiles_for(source: Tree, package: String) -> CargoProfileData {
    CargoProfileData {
        dev: profile_spec_from_root(source, "dev"),
        release: profile_spec_from_root(source, "release"),
        dev_build_override: profile_build_override_spec_from_root(source, "dev"),
        release_build_override: profile_build_override_spec_from_root(source, "release"),
        dev_package: profile_package_spec_from_root(source, "dev", package),
        release_package: profile_package_spec_from_root(source, "release", package),
    }
}

fn dev_profile_defaults() -> CargoResolvedProfile {
    CargoResolvedProfile {
        name: "dev",
        opt_level: "0",
        debuginfo: "2",
        debug_assertions: "true",
        overflow_checks: "true",
        panic: "unwind",
        lto: "false",
        codegen_units: "",
        strip: "none",
    }
}

fn release_profile_defaults() -> CargoResolvedProfile {
    CargoResolvedProfile {
        name: "release",
        opt_level: "3",
        debuginfo: "0",
        debug_assertions: "false",
        overflow_checks: "false",
        panic: "unwind",
        lto: "false",
        codegen_units: "16",
        strip: "none",
    }
}

fn profile_defaults(name: String) -> CargoResolvedProfile {
    match name == "release" {
        true => release_profile_defaults(),
        false => dev_profile_defaults(),
    }
}

fn host_profile_defaults() -> CargoProfileSpec {
    CargoProfileSpec {
        opt_level: "",
        debuginfo: "0",
        debug_assertions: "",
        overflow_checks: "",
        panic: "",
        lto: "",
        codegen_units: "",
        strip: "",
    }
}

fn nonempty_or(value: String, fallback: String) -> String {
    match value == "" {
        true => fallback,
        false => value,
    }
}

fn profile_apply(base: CargoResolvedProfile, spec: CargoProfileSpec) -> CargoResolvedProfile {
    CargoResolvedProfile {
        name: base.name,
        opt_level: nonempty_or(spec.opt_level, base.opt_level),
        debuginfo: nonempty_or(spec.debuginfo, base.debuginfo),
        debug_assertions: nonempty_or(spec.debug_assertions, base.debug_assertions),
        overflow_checks: nonempty_or(spec.overflow_checks, base.overflow_checks),
        panic: nonempty_or(spec.panic, base.panic),
        lto: nonempty_or(spec.lto, base.lto),
        codegen_units: nonempty_or(spec.codegen_units, base.codegen_units),
        strip: nonempty_or(spec.strip, base.strip),
    }
}

fn package_profile_spec(data: CargoProfileData, name: String) -> CargoProfileSpec {
    match name == "release" {
        true => data.release_package,
        false => data.dev_package,
    }
}

fn root_profile_spec(data: CargoProfileData, name: String) -> CargoProfileSpec {
    match name == "release" {
        true => data.release,
        false => data.dev,
    }
}

fn build_override_profile_spec(data: CargoProfileData, name: String) -> CargoProfileSpec {
    match name == "release" {
        true => data.release_build_override,
        false => data.dev_build_override,
    }
}

fn unit_uses_host_profile(unit_kind: String) -> Bool {
    match unit_kind == "build-script" {
        true => true,
        false => unit_kind == "build-dependency",
    }
}

fn unit_uses_build_override(unit_kind: String) -> Bool {
    match unit_kind == "proc-macro" {
        true => true,
        false => unit_uses_host_profile(unit_kind),
    }
}

fn resolved_profile(data: CargoProfileData, package: String, unit_kind: String, name: String) -> CargoResolvedProfile {
    let base = profile_apply(profile_defaults(name), root_profile_spec(data, name));
    let host_base = match unit_uses_host_profile(unit_kind) {
        true => profile_apply(base, host_profile_defaults()),
        false => base,
    };
    let build_override = match unit_uses_build_override(unit_kind) {
        true => profile_apply(host_base, build_override_profile_spec(data, name)),
        false => host_base,
    };

    // Cargo's Profiles reference says build-override covers build scripts, proc
    // macros, and their dependencies, and that named package overrides take precedence.
    // The unit-graph oracle exposes debuginfo=0 host defaults for build scripts/deps;
    // proc macros still receive explicit build-override settings.
    profile_apply(build_override, package_profile_spec(data, name))
}

fn default_resolved_profile(unit_kind: String, package: String) -> CargoResolvedProfile {
    resolved_profile(
        CargoProfileData {
            dev: empty_profile_spec(),
            release: empty_profile_spec(),
            dev_build_override: empty_profile_spec(),
            release_build_override: empty_profile_spec(),
            dev_package: empty_profile_spec(),
            release_package: empty_profile_spec(),
        },
        package,
        unit_kind,
        "dev",
    )
}

pub fn resolved_profile_for(source: Tree, package: String, unit_kind: String, name: String) -> CargoResolvedProfile {
    resolved_profile(cargo_profiles_for(source, package), package, unit_kind, name)
}

fn push_codegen_units(args: [String], units: String) -> [String] {
    match units == "" {
        true => args,
        false => args.push("-C").push("codegen-units=" + units),
    }
}

fn rustc_profile_args(profile: CargoResolvedProfile) -> [String] {
    let args: [String] = [];
    let args = args.push("-C").push("opt-level=" + profile.opt_level);
    let args = args.push("-C").push("debuginfo=" + profile.debuginfo);
    let args = args.push("-C").push("debug-assertions=" + profile.debug_assertions);
    let args = args.push("-C").push("overflow-checks=" + profile.overflow_checks);
    let args = args.push("-C").push("panic=" + profile.panic);
    let args = args.push("-C").push("lto=" + profile.lto);
    push_codegen_units(args, profile.codegen_units)
}

fn rustc_profile_args_opt(profile: Option<CargoResolvedProfile>) -> [String] {
    match profile {
        Some(p) => rustc_profile_args(p),
        None => [],
    }
}

fn rustc_extern_args(externs: [RustExtern], out: [Arg]) -> [Arg] {
    match externs.len() == 0 {
        true => out,
        false => rustc_extern_args_tuple(externs.pop(), out),
    }
}

fn rustc_extern_args_tuple(popped: (RustExtern, [RustExtern]), out: [Arg]) -> [Arg] {
    let next = rustc_extern_args(popped.1, out);
    next.push(Arg::Str("--extern")).push(Arg::Str(popped.0.name + "=")).push(Arg::Interpolation { tree: popped.0.tree, subpath: popped.0.subpath })
}

fn rustc_dependency_args(trees: [Tree], out: [Arg]) -> [Arg] {
    match trees.len() == 0 {
        true => out,
        false => rustc_dependency_args_tuple(trees.pop(), out),
    }
}

fn rustc_dependency_args_tuple(popped: (Tree, [Tree]), out: [Arg]) -> [Arg] {
    let next = rustc_dependency_args(popped.1, out);
    next.push(Arg::Str("-L")).push(Arg::Str("dependency=")).push(Arg::Interpolation { tree: popped.0, subpath: p"" })
}

fn rustc_crate_type(kind: CargoUnitKind) -> String {
    match kind {
        CargoUnitKind::ProcMacro => "proc-macro",
        CargoUnitKind::BuildScript => "bin",
        CargoUnitKind::BuildDependency => "lib",
        CargoUnitKind::Bin => "bin",
        CargoUnitKind::Lib => "lib",
    }
}

pub fn tree_union(trees: [Tree]) -> Tree {
    trees.pop().0
}

fn tree_union_from(trees: [Tree], out: Tree) -> Tree {
    match trees.len() == 0 {
        true => out,
        false => tree_union_tuple(trees.pop(), out),
    }
}

fn tree_union_tuple(popped: (Tree, [Tree]), out: Tree) -> Tree {
    tree_union_from(popped.1, out)
}

pub fn compile_rust_unit(unit: RustUnit) -> Tree {
    let rustc = Rustc::acquire(unit.target);
    let edition = unit.edition;
    let profile_args = rustc_profile_args_opt(unit.profile);
    let cfg_args = rustc_cfg_args(unit.cfgs, []);
    let dep_args = rustc_dependency_args(unit.deps_trees, []);
    let extern_args = rustc_extern_args(unit.externs, []);
    let source_arg = Arg::Interpolation { tree: unit.manifest, subpath: unit.source };
    let crate_type = rustc_crate_type(unit.crate_type);

    match unit.emit_metadata {
        Some(metadata) => match unit.emit_link {
            Some(link) => rustc! {
                --crate-name {unit.crate_name}
                --edition {edition}
                --crate-type {crate_type}
                {profile_args}
                {cfg_args}
                {unit.env}
                --emit=metadata={metadata},link={link}
                {dep_args}
                {extern_args}
                {source_arg}
            },
            None => rustc! {
                --crate-name {unit.crate_name}
                --edition {edition}
                --crate-type {crate_type}
                {profile_args}
                {cfg_args}
                {unit.env}
                --emit=metadata={metadata}
                {dep_args}
                {extern_args}
                {source_arg}
            },
        },
        None => match unit.emit_link {
            Some(link) => rustc! {
                --crate-name {unit.crate_name}
                --edition {edition}
                --crate-type {crate_type}
                {profile_args}
                {cfg_args}
                {unit.env}
                --emit=link={link}
                {dep_args}
                {extern_args}
                {source_arg}
            },
            None => rustc! {
                --crate-name {unit.crate_name}
                --edition {edition}
                --crate-type {crate_type}
                {profile_args}
                {cfg_args}
                {unit.env}
                {dep_args}
                {extern_args}
                {source_arg}
            },
        },
    }
}

struct BuildScriptMetadata {
    key: String,
    value: String,
}

struct BuildScriptOutDirRef {
    tree: Tree,
    subpath: Path,
}

struct BuildScriptUnitEffects {
    rustc_cfg: [String],
    rustc_check_cfg: [String],
    rustc_env: [String],
    rustc_link_lib: [String],
    rustc_link_search: [String],
    rerun_if_changed: [String],
    rerun_if_env_changed: [String],
    warning: [String],
    metadata: [BuildScriptMetadata],
    out_dir: BuildScriptOutDirRef,
}

struct BuildScriptDirectives {
    rustc_cfg: [String],
    rustc_check_cfg: [String],
    rustc_env: [String],
    rustc_link_lib: [String],
    rustc_link_search: [String],
    rerun_if_changed: [String],
    rerun_if_env_changed: [String],
    warning: [String],
    metadata: [BuildScriptMetadata],
}

fn resolved_unit(graph: ResolvedGraph, ix: Int) -> ResolvedUnit {
    graph.units.get(ix).unwrap()
}

fn unit_target(targets: UnitTargetTable, pkg: Int) -> UnitTarget {
    targets.targets.get(pkg).unwrap()
}

fn extern_file(unit: ResolvedUnit, mode: String) -> String {
    unit.link_file
}

fn direct_extern_args(graph: ResolvedGraph, deps: [Int], mode: String, out: [String]) -> [String] {
    match deps.len() == 0 {
        true => out,
        false => direct_extern_args_tuple(graph, deps.pop(), mode, out),
    }
}

fn direct_extern_args_tuple(graph: ResolvedGraph, popped: (Int, [Int]), mode: String, out: [String]) -> [String] {
    direct_extern_args_one(graph, popped.0, popped.1, mode, out)
}

fn direct_extern_args_one(graph: ResolvedGraph, dep: Int, rest: [Int], mode: String, out: [String]) -> [String] {
    let unit = resolved_unit(graph, dep);
    let arg = unit.name + "=/m/0/" + extern_file(unit, mode);
    direct_extern_args(graph, rest, mode, out.push("--extern").push(arg))
}

fn dependency_artifacts(target: Target, source: Tree, graph: ResolvedGraph, deps: [Int], mode: String, out: [Tree]) -> [Tree] {
    match deps.len() == 0 {
        true => out,
        false => dependency_artifacts_tuple(target, source, graph, deps.pop(), mode, out),
    }
}

fn dependency_artifacts_tuple(target: Target, source: Tree, graph: ResolvedGraph, popped: (Int, [Int]), mode: String, out: [Tree]) -> [Tree] {
    dependency_artifacts_one(target, source, graph, popped.0, popped.1, mode, out)
}

fn dependency_artifacts_one(target: Target, source: Tree, graph: ResolvedGraph, dep: Int, rest: [Int], mode: String, out: [Tree]) -> [Tree] {
    let unit = resolved_unit(graph, dep);
    let nested = dependency_artifacts(target, source, graph, unit.deps, mode, out);
    let built = resolved_unit_built(target, source, graph, unit, mode);
    dependency_artifacts(target, source, graph, rest, mode, nested.push(built))
}

fn dependency_tree(target: Target, source: Tree, graph: ResolvedGraph, unit: ResolvedUnit, mode: String) -> Tree {
    let artifacts: [Tree] = dependency_artifacts(target, source, graph, unit.deps, mode, []);
    artifacts.collect()
}

fn generic_lib_no_deps(target: Target, source: Tree, unit: ResolvedUnit) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = source / unit.manifest;
    let edition = doc_string(package_doc(manifest), "edition");
    let profile_args = rustc_profile_args(unit.profile);

    rustc! {
        --crate-name {unit.name}
        --edition {edition}
        --crate-type lib
        {profile_args}
        --emit=metadata={unit.metadata},link={unit.link}
        {manifest / unit.source}
    }
}

fn generic_lib_with_deps(target: Target, source: Tree, graph: ResolvedGraph, unit: ResolvedUnit, mode: String) -> Tree {
    match unit.deps.len() == 1 {
        true => generic_lib_with_one_dep(target, source, graph, unit, mode, unit.deps.pop().0),
        false => generic_lib_with_dynamic_deps(target, source, graph, unit, mode),
    }
}

fn generic_lib_with_one_dep(target: Target, source: Tree, graph: ResolvedGraph, unit: ResolvedUnit, mode: String, dep: Int) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = source / unit.manifest;
    let edition = doc_string(package_doc(manifest), "edition");
    let deps = dependency_tree(target, source, graph, unit, mode);
    let dep_unit = resolved_unit(graph, dep);
    let dep_artifact = resolved_unit_artifact(target, source, graph, dep, mode);
    let dep_extern = dep_unit.name + "=";
    let profile_args = rustc_profile_args(unit.profile);

    rustc! {
        --crate-name {unit.name}
        --edition {edition}
        --crate-type lib
        {profile_args}
        --emit=metadata={unit.metadata},link={unit.link}
        -L dependency={deps}
        --extern {dep_extern}{dep_artifact}
        {manifest / unit.source}
    }
}

fn generic_lib_with_dynamic_deps(target: Target, source: Tree, graph: ResolvedGraph, unit: ResolvedUnit, mode: String) -> Tree {
    let rustc = Rustc::acquire(target);
    let manifest = source / unit.manifest;
    let edition = doc_string(package_doc(manifest), "edition");
    let deps = dependency_tree(target, source, graph, unit, mode);
    let externs = direct_extern_args(graph, unit.deps, mode, []);
    let profile_args = rustc_profile_args(unit.profile);

    rustc! {
        --crate-name {unit.name}
        --edition {edition}
        --crate-type lib
        {profile_args}
        --emit=metadata={unit.metadata},link={unit.link}
        -L dependency={deps}
        {externs}
        {manifest / unit.source}
    }
}

fn generic_lib(target: Target, source: Tree, graph: ResolvedGraph, unit: ResolvedUnit, mode: String) -> Tree {
    match unit.deps.len() == 0 {
        true => generic_lib_no_deps(target, source, unit),
        false => generic_lib_with_deps(target, source, graph, unit, mode),
    }
}

