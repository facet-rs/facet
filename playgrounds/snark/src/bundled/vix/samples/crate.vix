fn solution_bin_link(target: Target, source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, unit: ResolvedUnit) -> Tree {
    match unit.deps.len() == 0 {
        true => solution_bin_link_no_deps(target, source, unit),
        false => match unit.deps.len() == 1 {
            true => solution_bin_link_with_one_dep(target, source, index, result, targets, target_name, unit, unit.deps.pop().0),
            false => solution_bin_link_with_two_deps(target, source, index, result, targets, target_name, unit, unit.deps.pop()),
        },
    }
}

fn solution_bin(target: Target, source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, unit: ResolvedUnit, mode: String) -> Tree {
    match mode == "metadata" {
        true => solution_bin_check(target, source, index, result, targets, target_name, unit),
        false => solution_bin_link(target, source, index, result, targets, target_name, unit),
    }
}

fn target_arch_env(target_name: String) -> String {
    target_name.before("-")
}

fn target_after_arch(target_name: String) -> String {
    target_name.after("-")
}

fn target_vendor_env(target_name: String) -> String {
    target_after_arch(target_name).before("-")
}

fn target_after_vendor(target_name: String) -> String {
    target_after_arch(target_name).after("-")
}

fn target_os_env(target_name: String) -> String {
    match target_name.contains("apple-darwin") {
        true => "macos",
        false => match target_name.contains("unknown-linux") {
            true => "linux",
            false => match target_name.contains("pc-windows") {
                true => "windows",
                false => target_after_vendor(target_name).before("-"),
            },
        },
    }
}

fn target_env_env(target_name: String) -> String {
    match target_after_vendor(target_name).contains("-") {
        true => target_after_vendor(target_name).after("-"),
        false => "",
    }
}

fn target_endian_env(target_name: String) -> String {
    "little"
}

fn solution_build_script_compile(source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, pkg: Int, unit: ResolvedUnit) -> Tree {
    let rustc = Rustc::acquire(Target::host());
    let manifest = source / unit.manifest;
    let edition = package_edition_from_source(source, manifest);
    let deps = solution_dependency_tree(Target::host(), source, index, result, targets, target_name, unit, "link");
    let externs = solution_extern_args(Target::host(), index, result, targets, source, target_name, unit.deps, "link", []);
    let profile_args = rustc_profile_args(unit.profile);
    let cfg_args = push_cfg_args(unit.cfgs, []);
    let source_arg = argv_source_interpolation(manifest, unit.source);

    rustc! {
        --crate-name {unit.name}
        --edition {edition}
        --crate-type bin
        {profile_args}
        {cfg_args}
        --env CARGO_MANIFEST_DIR={manifest}
        --emit=link={unit.link}
        -L dependency={deps}
        {externs}
        {source_arg}
    }
}

fn solution_build_script_run(source: Tree, target_name: String, unit: ResolvedUnit, binary: Tree) -> Tree {
    let build_script = "build-script-runner";
    let manifest = source / unit.manifest;
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let version = doc_string(package, "version");
    let arch = target_arch_env(target_name);
    let vendor = target_vendor_env(target_name);
    let os = target_os_env(target_name);
    let env = target_env_env(target_name);
    let endian = target_endian_env(target_name);

    build_script! {
        --requires-toolchain=cc
        --executable {binary / unit.link}
        --stdout {p"build.stdout"}
        --out-dir {p"out"}
        --env OUT_DIR={p"out"}
        --env CARGO_MANIFEST_DIR={manifest}
        --env CARGO_PKG_NAME={name}
        --env CARGO_PKG_VERSION={version}
        --env CARGO_PKG_VERSION_MAJOR=0
        --env CARGO_PKG_VERSION_MINOR=1
        --env CARGO_PKG_VERSION_PATCH=0
        --env CARGO_PKG_VERSION_PRE=
        --env TARGET={target_name}
        --env HOST={target_name}
        --env RUSTC=rustc
        --env OPT_LEVEL=3
        --env PROFILE=debug
        --env CARGO_CFG_TARGET_ARCH={arch}
        --env CARGO_CFG_TARGET_VENDOR={vendor}
        --env CARGO_CFG_TARGET_OS={os}
        --env CARGO_CFG_TARGET_ENV={env}
        --env CARGO_CFG_TARGET_ENDIAN={endian}
    }
}

fn solution_build_script(target: Target, source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, pkg: Int, unit: ResolvedUnit) -> Tree {
    let binary = solution_build_script_compile(source, index, result, targets, target_name, pkg, unit);
    solution_build_script_run(source, target_name, unit, binary)
}

fn solution_unit_built(target: Target, source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, pkg: Int, mode: String) -> Tree {
    let unit = solution_unit(index, result, targets, source, target_name, pkg);
    match unit.kind == "lib" {
        true => solution_lib(target, source, index, result, targets, target_name, unit, mode),
        false => match unit.kind == "build-dependency" {
            true => solution_lib(target, source, index, result, targets, target_name, unit, mode),
            false => match unit.kind == "proc-macro" {
                true => solution_proc_macro(source, index, result, targets, target_name, unit),
                false => match unit.kind == "build-script" {
                    true => solution_build_script(target, source, index, result, targets, target_name, pkg, unit),
                    false => solution_bin(target, source, index, result, targets, target_name, unit, mode),
                },
            },
        },
    }
}

fn solution_unit_artifact(target: Target, source: Tree, index: Index, result: SolveResult, targets: UnitTargetTable, target_name: String, pkg: Int, mode: String) -> Tree {
    let unit = solution_unit(index, result, targets, source, target_name, pkg);
    let built = solution_unit_built(target, source, index, result, targets, target_name, pkg, mode);
    built / solution_unit_artifact_path(unit, mode)
}

pub fn crate_solution_bin_check(target: Target, source: Tree, index: Index, problem: Problem, target_name: String, targets: UnitTargetTable) -> Tree {
    let result = solve(index, problem, target_name);
    let root = targets.root;
    solution_unit_artifact(target, source, index, result, targets, target_name, root, "metadata")
}

pub fn crate_solution_bin(target: Target, source: Tree, index: Index, problem: Problem, target_name: String, targets: UnitTargetTable) -> Tree {
    let result = solve(index, problem, target_name);
    let root = targets.root;
    solution_unit_artifact(target, source, index, result, targets, target_name, root, "link")
}

fn build_script_compile(manifest: Tree) -> Tree {
    let rustc = Rustc::acquire(Target::host());
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name build_script_build
        --edition {edition}
        --crate-type bin
        --emit=link={p"build_script"}
        {manifest / p"build.rs"}
    }
}

fn build_script_run(manifest: Tree, binary: Tree) -> Tree {
    let build_script = "build-script-runner";
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let version = doc_string(package, "version");

    build_script! {
        --executable {binary / p"build_script"}
        --stdout {p"build.stdout"}
        --out-dir {p"out"}
        --env OUT_DIR={p"out"}
        --env CARGO_MANIFEST_DIR={manifest}
        --env CARGO_PKG_NAME={name}
        --env CARGO_PKG_VERSION={version}
        --env CARGO_PKG_VERSION_MAJOR=0
        --env CARGO_PKG_VERSION_MINOR=1
        --env CARGO_PKG_VERSION_PATCH=0
        --env CARGO_PKG_VERSION_PRE=
        --env TARGET=x86_64-unknown-linux-gnu
        --env HOST=x86_64-unknown-linux-gnu
        --env RUSTC=rustc
        --env OPT_LEVEL=0
        --env PROFILE=debug
    }
}

fn empty_build_script_directives() -> BuildScriptDirectives {
    BuildScriptDirectives {
        rustc_cfg: [],
        rustc_check_cfg: [],
        rustc_env: [],
        rustc_link_lib: [],
        rustc_link_search: [],
        rerun_if_changed: [],
        rerun_if_env_changed: [],
        warning: [],
        metadata: [],
    }
}

fn malformed_build_script_directive(line: String) -> String {
    let missing: Map<String, String> = {};
    missing.get(line).unwrap()
}

fn cargo_directive_payload(line: String) -> String {
    let double_colon = line.strip_prefix("cargo::");
    match double_colon == line {
        true => match line.strip_prefix("cargo:") {
            single_colon => match single_colon == line {
                true => malformed_build_script_directive(line),
                false => single_colon,
            },
        },
        false => double_colon,
    }
}

fn checked_directive_payload(line: String) -> String {
    let payload = cargo_directive_payload(line);
    match payload.contains("=") {
        true => payload,
        false => malformed_build_script_directive(line),
    }
}

fn is_cargo_directive_line(line: String) -> Bool {
    match line.contains(":") {
        true => line.before(":") == "cargo",
        false => false,
    }
}

fn metadata_directive(key: String, value: String) -> BuildScriptMetadata {
    match key == "metadata" {
        true => match value.contains("=") {
            true => BuildScriptMetadata { key: value.before("="), value: value.after("=") },
            false => BuildScriptMetadata { key: malformed_build_script_directive(value), value: value },
        },
        false => BuildScriptMetadata { key: key, value: value },
    }
}

fn build_script_directive_line(line: String, directives: BuildScriptDirectives) -> BuildScriptDirectives {
    match line == "" {
        true => directives,
        false => match is_cargo_directive_line(line) {
            true => build_script_directive_payload(checked_directive_payload(line), directives),
            false => directives,
        },
    }
}

fn build_script_directive_payload(payload: String, directives: BuildScriptDirectives) -> BuildScriptDirectives {
    let key = payload.before("=");
    let value = payload.after("=");
    match key == "rustc-cfg" {
        true => BuildScriptDirectives { rustc_cfg: directives.rustc_cfg.push(value), ..directives },
        false => match key == "rustc-check-cfg" {
            true => BuildScriptDirectives { rustc_check_cfg: directives.rustc_check_cfg.push(value), ..directives },
            false => match key == "rustc-env" {
                true => BuildScriptDirectives { rustc_env: directives.rustc_env.push(value), ..directives },
                false => match key == "rustc-link-lib" {
                    true => BuildScriptDirectives { rustc_link_lib: directives.rustc_link_lib.push(value), ..directives },
                    false => match key == "rustc-link-search" {
                        true => BuildScriptDirectives { rustc_link_search: directives.rustc_link_search.push(value), ..directives },
                        false => match key == "rerun-if-changed" {
                            true => BuildScriptDirectives { rerun_if_changed: directives.rerun_if_changed.push(value), ..directives },
                            false => match key == "rerun-if-env-changed" {
                                true => BuildScriptDirectives { rerun_if_env_changed: directives.rerun_if_env_changed.push(value), ..directives },
                                false => match key == "warning" {
                                    true => BuildScriptDirectives { warning: directives.warning.push(value), ..directives },
                                    false => BuildScriptDirectives { metadata: directives.metadata.push(metadata_directive(key, value)), ..directives },
                                },
                            },
                        },
                    },
                },
            },
        },
    }
}

fn parse_build_script_directive_lines(stdout: String, directives: BuildScriptDirectives) -> BuildScriptDirectives {
    match stdout.contains("\n") {
        true => parse_build_script_directive_lines(stdout.after("\n"), build_script_directive_line(stdout.before("\n"), directives)),
        false => build_script_directive_line(stdout, directives),
    }
}

fn build_script_directives_from_stdout(stdout: String) -> BuildScriptDirectives {
    parse_build_script_directive_lines(stdout, empty_build_script_directives())
}

fn build_script_directives(run: Tree) -> BuildScriptDirectives {
    build_script_directives_from_stdout(run.text(p"build.stdout"))
}

pub fn build_script_rustc_cfgs(run: Tree) -> [String] {
    build_script_directives(run).rustc_cfg
}

fn build_script_out_dir(run: Tree) -> Tree {
    run / p"out"
}

fn build_script_out_dir_ref(run: Tree) -> BuildScriptOutDirRef {
    BuildScriptOutDirRef { tree: run, subpath: p"out" }
}

// Cargo's rerun-if-* directives are DECLARED-world receipts: Cargo needs them
// because it cannot see. Vix invalidation authority stays with OBSERVED
// hermetic read-sets; declared/observed divergence is recorded data.
fn build_script_unit_effects(run: Tree, directives: BuildScriptDirectives) -> BuildScriptUnitEffects {
    BuildScriptUnitEffects {
        rustc_cfg: directives.rustc_cfg,
        rustc_check_cfg: directives.rustc_check_cfg,
        rustc_env: directives.rustc_env,
        rustc_link_lib: directives.rustc_link_lib,
        rustc_link_search: directives.rustc_link_search,
        rerun_if_changed: directives.rerun_if_changed,
        rerun_if_env_changed: directives.rerun_if_env_changed,
        warning: directives.warning,
        metadata: directives.metadata,
        out_dir: build_script_out_dir_ref(run),
    }
}

fn rustc_cfg_args(values: [String], out: [Arg]) -> [Arg] {
    match values.len() == 0 {
        true => out,
        false => rustc_cfg_args_tuple(values.pop(), out),
    }
}

fn rustc_cfg_args_tuple(popped: (String, [String]), out: [Arg]) -> [Arg] {
    let next = rustc_cfg_args(popped.1, out);
    next.push(Arg::Str("--cfg")).push(Arg::Str(popped.0))
}

fn rustc_check_cfg_args(values: [String], out: [Arg]) -> [Arg] {
    match values.len() == 0 {
        true => out,
        false => rustc_check_cfg_args_tuple(values.pop(), out),
    }
}

fn rustc_check_cfg_args_tuple(popped: (String, [String]), out: [Arg]) -> [Arg] {
    let next = rustc_check_cfg_args(popped.1, out);
    next.push(Arg::Str("--check-cfg")).push(Arg::Str(popped.0))
}

fn rustc_env_args(values: [String], out: [Arg]) -> [Arg] {
    match values.len() == 0 {
        true => out,
        false => rustc_env_args_tuple(values.pop(), out),
    }
}

fn rustc_env_args_tuple(popped: (String, [String]), out: [Arg]) -> [Arg] {
    let next = rustc_env_args(popped.1, out);
    next.push(Arg::Str("--env")).push(Arg::Str(popped.0))
}

fn out_dir_env_arg(out_dir: BuildScriptOutDirRef) -> [Arg] {
    [
        Arg::Str("--env"),
        Arg::Str("OUT_DIR="),
        Arg::Interpolation { tree: out_dir.tree, subpath: out_dir.subpath },
    ]
}

fn dep_metadata_env_name(links: String, metadata: BuildScriptMetadata) -> String {
    "DEP_" + links + "_" + metadata.key
}

fn dep_metadata_env_value(links: String, metadata: BuildScriptMetadata) -> String {
    dep_metadata_env_name(links, metadata) + "=" + metadata.value
}

fn dep_metadata_env_values(links: String, metadata: [BuildScriptMetadata], out: [String]) -> [String] {
    match metadata.len() == 0 {
        true => out,
        false => dep_metadata_env_values_tuple(links, metadata.pop(), out),
    }
}

fn dep_metadata_env_values_tuple(links: String, popped: (BuildScriptMetadata, [BuildScriptMetadata]), out: [String]) -> [String] {
    let next = dep_metadata_env_values(links, popped.1, out);
    next.push(dep_metadata_env_value(links, popped.0))
}

fn build_script_lib(target: Target, manifest: Tree, effects: BuildScriptUnitEffects) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");
    let cfg_args = rustc_cfg_args(effects.rustc_cfg, []);
    let check_cfg_args = rustc_check_cfg_args(effects.rustc_check_cfg, []);
    let env_args = rustc_env_args(effects.rustc_env, []);
    let out_dir_env = out_dir_env_arg(effects.out_dir);

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type lib
        {cfg_args}
        {check_cfg_args}
        {env_args}
        {out_dir_env}
        --emit=metadata={p"libbuild_script_app.rmeta"},link={p"libbuild_script_app.rlib"}
        {manifest / p"src/lib.rs"}
    }
}

fn build_script_bin_link(target: Target, manifest: Tree, lib: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let edition = doc_string(package_doc(manifest), "edition");

    rustc! {
        --crate-name build_script_runner
        --edition {edition}
        --crate-type bin
        --emit=link={p"build_script_runner"}
        --extern build_script_app={lib / p"libbuild_script_app.rlib"}
        -L dependency={lib}
        {manifest / p"src/main.rs"}
    }
}

pub fn crate_build_script_directive_cfg(graph: Tree) -> String {
    let manifest = graph / p"app";
    let binary = build_script_compile(manifest);
    let run = build_script_run(manifest, binary);
    let directives = build_script_directives(run);
    directives.rustc_cfg.join(" ")
}

pub fn crate_build_script_directive_cfg_from_stdout(stdout: String) -> String {
    build_script_directives_from_stdout(stdout).rustc_cfg.join(" ")
}

pub fn crate_build_script_directive_env_from_stdout(stdout: String) -> String {
    build_script_directives_from_stdout(stdout).rustc_env.join(",")
}

pub fn crate_build_script_directive_links_from_stdout(stdout: String) -> String {
    let directives = build_script_directives_from_stdout(stdout);
    directives.rustc_link_lib.join(",") + "|" + directives.rustc_link_search.join(",")
}

pub fn crate_build_script_directive_rerun_from_stdout(stdout: String) -> String {
    let directives = build_script_directives_from_stdout(stdout);
    directives.rerun_if_changed.join(",") + "|" + directives.rerun_if_env_changed.join(",")
}

pub fn crate_build_script_dep_metadata_env_from_stdout(stdout: String, links: String) -> String {
    dep_metadata_env_values(links, build_script_directives_from_stdout(stdout).metadata, []).join(",")
}

pub fn crate_build_script_out_dir(graph: Tree) -> Tree {
    let manifest = graph / p"app";
    let binary = build_script_compile(manifest);
    let run = build_script_run(manifest, binary);
    build_script_out_dir(run)
}

pub fn crate_build_script_bin(target: Target, graph: Tree) -> Tree {
    let manifest = graph / p"app";
    let binary = build_script_compile(manifest);
    let run = build_script_run(manifest, binary);
    let directives = build_script_directives(run);
    let effects = build_script_unit_effects(run, directives);
    let lib = build_script_lib(target, manifest, effects);
    build_script_bin_link(target, manifest, lib) / p"build_script_runner"
}

fn proc_macro_dylib_ext(host: Target) -> String {
    match host.os {
        Os::Macos => "dylib",
        Os::Windows => "dll",
        _ => "so",
    }
}

fn proc_macro_dylib_file(host: Target) -> String {
    "libemit_answer_macro." + proc_macro_dylib_ext(host)
}

fn proc_macro_dylib_path(host: Target) -> Path {
    p"libemit_answer_macro.so".with_ext(proc_macro_dylib_ext(host))
}

fn proc_macro_dylib(manifest: Tree) -> Tree {
    let host = Target::host();
    let rustc = Rustc::acquire(host);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");
    let dylib = proc_macro_dylib_path(host);

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type proc-macro
        --emit=link={dylib}
        {manifest / p"src/lib.rs"}
    }
}

fn proc_macro_bin_link(target: Target, manifest: Tree, macro_dylib: Tree) -> Tree {
    let rustc = Rustc::acquire(target);
    let package = package_doc(manifest);
    let name = doc_string(package, "name");
    let edition = doc_string(package, "edition");
    let dylib = proc_macro_dylib_path(Target::host());

    rustc! {
        --crate-name {name}
        --edition {edition}
        --crate-type bin
        --emit=link={p"macro_app"}
        --extern emit_answer_macro={macro_dylib / dylib}
        -L dependency={macro_dylib}
        {manifest / p"src/main.rs"}
    }
}

pub fn crate_proc_macro_bin(target: Target, graph: Tree) -> Tree {
    let macro_crate = graph / p"crates/emit_answer_macro";
    let root = graph / p"app";
    let macro_dylib = proc_macro_dylib(macro_crate);
    proc_macro_bin_link(target, root, macro_dylib) / p"macro_app"
}

fn proc_macro_cross_target() -> Target {
    let host = Target::host();
    match host.os {
        Os::Linux => Target { os: Os::Macos },
        _ => Target { os: Os::Linux },
    }
}

pub fn crate_proc_macro_cross_bin(graph: Tree) -> Tree {
    crate_proc_macro_bin(proc_macro_cross_target(), graph)
}
