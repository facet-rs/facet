    let edition = doc_string(package_doc(manifest), "edition");
    let deps = dependency_tree(target, source, graph, unit, "link");
    let externs = direct_extern_args(graph, unit.deps, "link", []);
    let profile_args = rustc_profile_args(unit.profile);

    rustc! {
        --crate-name {unit.name}
        --edition {edition}
