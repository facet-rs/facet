pub fn cargo_manifest(manifest: Tree) -> (String, String, String) {
    let doc = toml(manifest / p"Cargo.toml");
    let package = doc.get("package").unwrap();
    let deps = doc.get("dependencies").unwrap();
    let facet = deps.get("facet").unwrap();
    (
        package.get("name").unwrap(),
        package.get("version").unwrap(),
        facet.get("version").unwrap(),
    )
}
