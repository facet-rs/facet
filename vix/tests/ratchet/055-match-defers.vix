// Rung 055 — the untaken arm is never demanded. (demand.md)
enum Mode { Quick, Full }
fn cheap_summary() -> String { "ok" }
fn full_audit() -> String { "everything" }

test match_defers {
    let report = match Mode::Quick {
        Mode::Quick => cheap_summary(),
        Mode::Full => full_audit(),
    };
    expect_eq(report, "ok");
} expecting {
    never_demanded full_audit;
}
