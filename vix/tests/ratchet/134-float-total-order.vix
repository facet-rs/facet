// Rung 134 — floats have a TOTAL order (IEEE totalOrder): NaN equals
// itself and sorts last; sorting floats is deterministic. Value
// semantics require reflexive equality — there is no "NaN != NaN" here.
test float_total_order {
    let nan = 0.0 / 0.0;
    expect_eq(nan, nan);
    expect_eq([nan, 1.5, -2.0].values().sorted(), [-2.0, 1.5, nan]);
    expect(1.5 < nan);
}
