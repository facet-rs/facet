// Rung 008 — record update via spread: a fresh value, original untouched.
struct Point { x: Int, y: Int }

#[test]
fn spread() -> Stream<Check> {
    let p = Point { x: 3, y: 4 };
    let moved = Point { x: p.x + 1, ..p };
    yield expect_eq(moved.x, 4);
    yield expect_eq(moved.y, 4);
    yield expect_eq(p.x, 3);
}
