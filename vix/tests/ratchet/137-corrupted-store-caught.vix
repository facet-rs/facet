//! rerun with: corrupted-store

// Rung 137 — a persisted entry is corrupted between runs. Reverify-on-
// load catches it: the value recomputes and the answer is RIGHT. Trust
// nothing on record. (persistence.value-vs-claim, reverify-on-load)
fn costly(n: Int) -> Int { n * n }

test corrupted_store_caught {
    expect_eq(costly(1111), 1234321);
} expecting on rerun {
    demanded costly;
}
