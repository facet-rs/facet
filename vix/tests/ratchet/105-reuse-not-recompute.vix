//! rerun

// Rung 105 — reuse must be lookup, not recompute-and-compare: on the
// warm run the expensive function is never demanded AND the trace shows
// memo hits, not fresh computation that happened to match.
fn expensive(n: Int) -> Int { n * n * n }

test reuse_not_recompute {
    expect_eq(expensive(30), 27000);
} expecting on rerun {
    never_demanded expensive;
    memo_hits_at_least 1;
}
