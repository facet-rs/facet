
// Rung 081 — the two-step dance: the tree changed, but the sixty files
// you read didn't. Reuse without re-running. (three-planes.md)
fn build_step(tree: Tree) -> String {
    (tree / "src" / "main.c").text()
}

#[test { rerun_with: "readme-changed" }]
fn projection_reuse() -> Stream<Check> {
    let src = build_step(fixture_tree("readme-changed"));
    yield expect(src.contains("int main"));
    yield never_demanded(build_step(fixture_tree("readme-changed")));
}
