// Rung 077 — extract an archive into a Tree; project into it.
#[test]
fn archive_extract() -> Stream<Check> {
    let crate_bytes = fetch(fixture_registry().url("tokio-1.52.3.crate"));
    let tree = untar(crate_bytes);
    let manifest = (tree / "Cargo.toml").text();
    yield expect(manifest.contains("name = \"tokio\""));
}
