// Rung 036 — canonical fold sorts stream values before folding: deterministic,
// and NOT source order. (collections.md, the entry with teeth)
#[test]
fn multiset_fold() -> Stream<Check> {
    let ms = ["c", "a", "b"].stream();
    yield expect_eq(ms.collect().values().sorted().fold("", |acc, s| acc + s), "abc");
    let sum = [3, 1, 2].stream().collect().values().sorted().fold(0, |acc, n| acc + n);
    yield expect_eq(sum, 6);
}
