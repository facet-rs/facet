// Rung 023 — Option construction and matching.
fn checked_div(a: Int) where { b: Int } -> Option<Int> {
    if b == 0 { None } else { Some(a / b) }
}

#[test]
fn option() -> Stream<Check> {
    let quotient = checked_div(10) where { b: 2 };
    let zero_div = checked_div(1) where { b: 0 };
    yield expect_some(quotient);
    yield expect_none(zero_div);
    let doubled = match quotient {
        Some(n) => n * 2,
        None => 0,
    };
    yield expect_eq(doubled, 10);
}
