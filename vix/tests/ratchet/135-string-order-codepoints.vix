// Rung 135 — string canonical order is by Unicode scalar values:
// deterministic, locale-free, not byte-shuffled by encoding accidents.
#[test]
fn string_order_codepoints() -> Stream<Check> {
    yield expect("Z" < "a");                       // 0x5A < 0x61
    yield expect("a" < "é");                       // 0x61 < 0xE9
    yield expect_eq(["é", "a", "Z"].sorted(), ["Z", "a", "é"]);
}
