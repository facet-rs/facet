// Rung 088 — propagation to a contradiction yields a conflict value.
struct State { domains: Map<String, VersionSet>, selected: Map<String, Version> }
enum Step { Pass(State), Conflict(String) }

fn apply_dep(s: State) where { pkg: String, req: VersionSet } -> Step {
    let narrowed = s.domains.get(pkg).intersect(req);
    if narrowed.is_empty() { Step::Conflict(pkg) }
    else { Step::Pass(State { domains: s.domains.with (pkg, narrowed), ..s }) }
}

#[test]
fn propagate_conflicts() -> Stream<Check> {
    let s = State { domains: %{"libb" => parse_req("^1.0")}, selected: %{} };
    let step = apply_dep(s) where { pkg: "libb", req: parse_req("^2.0") };
    yield match step {
        Step::Conflict(pkg) => expect_eq(pkg, "libb"),
        Step::Pass(_) => expect(false),
    };
}
