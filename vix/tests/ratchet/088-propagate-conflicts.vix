// Rung 088 — propagation to a contradiction yields a conflict value.
struct State { domains: Map<String, VersionSet>, selected: Map<String, Version> }
enum Step { Pass(State), Conflict(String) }

fn apply_dep(s: State, pkg: String, req: VersionSet) -> Step {
    let narrowed = s.domains.get(pkg).unwrap().intersect(req);
    if narrowed.is_empty() { Step::Conflict(pkg) }
    else { Step::Pass(State { domains: s.domains.insert(pkg, narrowed), ..s }) }
}

test propagate_conflicts {
    let s = State { domains: {}.insert("libb", parse_req("^1.0")), selected: %{} };
    match apply_dep(s, "libb", parse_req("^2.0")) {
        Step::Conflict(pkg) => expect_eq(pkg, "libb"),
        Step::Pass(_) => expect(false),
    }
}
