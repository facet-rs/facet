// Rung 066 — a decode that can fail returns a result value, not a crash.
struct PkgRow { name: String, vers: String }

#[test]
fn decode_failure() -> Stream<Check> {
    let bad = try_json_decode<PkgRow>("{\"name\": 42}");
    yield match bad {
        Ok(_) => expect(false),
        Err(e) => expect(e.message.contains("name")),
    };
}
