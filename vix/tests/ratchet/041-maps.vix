// Rung 041 — Map<K, V>: insert returns a new map; lookup returns Option.
#[test]
fn maps() -> Stream<Check> {
    let m: Map<String, Int> = %{};
    let m2 = %{"a" => 1, "b" => 2};
    yield expect_eq(m2.get("a"), Some(1));
    yield expect_none(m2.get("z"));
    yield expect_eq(m.len(), 0);
    yield expect_eq(m2.len(), 2);
}
