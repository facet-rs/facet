// Rung 054 — a field access depends on that field alone. (demand.md)
struct Point { x: Int, y: Int }
fn cheap() -> Int { 41 }
fn expensive() -> Int { 999 }

#[test]
fn partial_dependency() -> Stream<Check> {
    let p = Point { x: cheap(), y: expensive() };
    yield expect_eq(p.x + 1, 42);
    yield never_demanded(expensive());
}
