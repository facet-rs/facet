// Rung 017 — match arm guards.
fn classify(n: Int) -> String {
    match n {
        x if x < 0 => "negative",
        0 => "zero",
        x if x < 10 => "small",
        _ => "large",
    }
}

test match_guards {
    expect_eq(classify(0 - 3), "negative");
    expect_eq(classify(0), "zero");
    expect_eq(classify(7), "small");
    expect_eq(classify(1000), "large");
}
