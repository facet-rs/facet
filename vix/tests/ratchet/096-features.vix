// Rung 096 — feature resolution: optional deps activate through features.
#[test]
fn features() -> Stream<Check> {
    let reqs = %{"libe" => parse_req("^1.0")};
    let features = %{"libe" => %["net"]};
    let solution = mini_solve_with_features(fixture_index()) where { requirements: reqs, features };
    yield match solution {
        Some(sel) => expect(sel.has("libnet")),
        None => expect(false),
    };
}
