
// Rung 129 — spawn-and-park: a demand that launches an effect must not
// hold the scheduler hostage while it waits. Two tests' worth of work
// interleaves with one slow effect (asserted by the overlap of the
// effect with pure work completing).
fn pure_work() -> Int { (range where { from: 0, to: 100000 }).fold(0, |a, i| a + i) }

#[test { budget_wall: 1s, budget_rss: 256MB }]
fn no_inline_draining(sh: Sh) -> Stream<Check> {
    let slow = exec sh`-c "sleep 0.5; echo x"`;
    let sum = pure_work();
    yield expect_eq(sum, 4999950000);
    yield expect_eq(slow.stdout.collect().values(), ["x"]);
    yield overlapped();
}
