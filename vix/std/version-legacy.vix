// Compatibility prelude owned exclusively by the retiring machine compiler.
// The new compiler owns version.vix and does not load this module.

pub enum Ordering {
    Less,
    Equal,
    Greater,
}

pub fn parse_version(s: String) -> Version {
    version(s)
}

pub fn version_lte(a: Version, b: Version) -> Bool {
    a <= b
}
