pub fn taxon_blake3_build_script_run_with_wrong_toolchain(workspace: Tree, sparse_jsonl: String, target_name: String) -> Tree {
    let state = taxon_state(workspace, sparse_jsonl);
    let graph = taxon_resolved_graph(workspace, sparse_jsonl, target_name);
    let unit_id = build_script_unit_id(state.package_ids.get("blake3").unwrap());
    let unit = resolved_unit(graph, unit_id);
    let binary = taxon_blake3_build_script_binary(workspace, sparse_jsonl, target_name);
    let build_script = "build-script-runner";
    let major = version_major(unit.version);
    let minor = version_minor(unit.version);
    let patch = version_patch(unit.version);
    let pre = version_pre(unit.version);
    let arch = target_arch_env(target_name);
    let vendor = target_vendor_env(target_name);
    let os = target_os_env(target_name);
    let target_env = target_env_env(target_name);

    build_script! {
        --requires-toolchain=zigcc
        --executable {binary / unit.link}
        --stdout {p"build.stdout"}
        --out-dir {p"out"}
        --env OUT_DIR={p"out"}
        --env CARGO_MANIFEST_DIR={unit.manifest}
        --env CARGO_PKG_NAME={unit.package_name}
        --env CARGO_PKG_VERSION={unit.version}
        --env CARGO_PKG_VERSION_MAJOR={major}
        --env CARGO_PKG_VERSION_MINOR={minor}
        --env CARGO_PKG_VERSION_PATCH={patch}
        --env CARGO_PKG_VERSION_PRE={pre}
        --env TARGET={target_name}
        --env HOST={target_name}
        --env RUSTC=rustc
        --env OPT_LEVEL=0
        --env PROFILE=debug
        --env CARGO_CFG_TARGET_ARCH={arch}
        --env CARGO_CFG_TARGET_VENDOR={vendor}
        --env CARGO_CFG_TARGET_OS={os}
        --env CARGO_CFG_TARGET_ENV={target_env}
        --env CARGO_CFG_TARGET_ENDIAN=little
    }
}

pub fn taxon_blake3_cfgs(workspace: Tree, sparse_jsonl: String, target_name: String) -> String {
    let run = taxon_blake3_build_script_run(workspace, sparse_jsonl, target_name);
    build_script_rustc_cfgs(run).join("\n")
}

pub fn taxon_blake3_link(workspace: Tree, sparse_jsonl: String, target_name: String) -> Tree {
    let state = taxon_state(workspace, sparse_jsonl);
    resolved_unit_built(Target::host(), taxon_resolved_graph(workspace, sparse_jsonl, target_name), lib_unit_id(state.package_ids.get("blake3").unwrap()))
}

pub fn taxon_root_link(workspace: Tree, sparse_jsonl: String, target_name: String) -> Tree {
    let graph = taxon_resolved_graph(workspace, sparse_jsonl, target_name);
    resolved_unit_built(Target::host(), graph, graph.root)
}
