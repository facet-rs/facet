---
source: crates/figue/tests/integration/simple.rs
expression: "strip_ansi_escapes :: strip_str(& help.to_string())"
---
main

USAGE:
    main [OPTIONS]

OPTIONS:
        --name <STRING>
    -h, --[no-]help
            Show help message and exit.
        --[no-]html-help
            Open HTML help in the browser and exit.
    -V, --[no-]version
            Show version and exit.
        --completions <bash,zsh,fish>
            Generate shell completions.
        --export-jsonschemas <DIR>
            Export JSON Schema files for all config roots.
